<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	<data>
		
		<record id="branch_master_tree_view1" model="ir.ui.view">
			<field name="name">Financial Year</field>
			<field name="model">branch.master</field>
			<field name="arch" type="xml">
				<list>
					<field name="name"/>
					<field name="company_id"/>
					<field name="description"/>
				</list>
			</field>
		</record>

		<record id="branch_master_form_view" model="ir.ui.view">
			<field name="name">Branch Master</field>
			<field name="model">branch.master</field>
			<field name="arch" type="xml">
				<form string="Branch Master form">
					<group>
						<group>
							<field name="logo_branch" widget="image" class="oe_avatar"/>
							<field name="name"/>
							<field name="company_id" options="{'no_create': True, 'no_open': True}"/>
							<label for="street" string="Address"/>
                            <div class="o_address_format">
                                <field name="street" placeholder="Street..." class="o_address_street"/>
                                <field name="street2" placeholder="Street 2..." class="o_address_street"/>
                                <field name="city" placeholder="City" class="o_address_city"/>
                                <field name="state_id" class="o_address_state" placeholder="State" options="{'no_create': True, 'no_open': True}"/>
                                <field name="zip" placeholder="ZIP" class="o_address_zip"/>
                                <field name="country_id" placeholder="Country" class="o_address_country" options="{'no_create': True, 'no_open': True}"/>
                            </div>
                            <field name="description"/>
						</group>
						<group>
							<field name="email"/>
							<field name="website" widget="url" placeholder="e.g. www.odoo.com"/>
							<field name="phone"/>
							<field name='pan_no'/>
				            <field name='cin_no'/>
				            <field name='gstin_no'/>
				            <field name='branch_code'/>
				            <field name='branch_format'/>
						</group>
					</group>
				</form>
			</field>
		</record>

		<record id="action_branch_master1" model="ir.actions.act_window">
			<field name="name">Branch Master</field>
			<field name="type">ir.actions.act_window</field>
			<field name="res_model">branch.master</field>
			<field name="view_id" ref="branch_master_tree_view1"/>
			<field name="view_mode">list,form</field>
		</record>

	</data>
</odoo>