<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	<data>

		<record id="term_and_condition_tree_view" model="ir.ui.view">
			<field name="name">term.and.condition.tree</field>
			<field name="model">term.and.condition</field>
			<field name="arch" type="xml">
				<list>
					<field name="name" />
				</list>
			</field>
		</record>
		
		<record id="term_and_condition_form_view" model="ir.ui.view">
			<field name="name">term.and.condition.form</field>
			<field name="model">term.and.condition</field>
			<field name="arch" type="xml">
				<form string="Terms &amp; Conditions">
					<sheet>
						<div class="oe_title">
							<label for="name" class="oe_edit_only" />
							<h1>
								<field name="name" placeholder="Name....." />
							</h1>
						</div>
						<notebook>
							<page string="Options">
								<field name="term_and_condition_line" >
									<list editable="bottom">
										<field name="term_and_condition_option_id" />
									</list>
									<form string="Terms &amp; Conditions Lines" >
										<field name="term_and_condition_option_id" />
									</form>
								</field>
							</page>
						</notebook>
					</sheet>
				</form>
			</field>
		</record> 
		
		<record id="action_term_and_condition" model="ir.actions.act_window">
			<field name="name">Terms &amp; Conditions</field>
			<field name="type">ir.actions.act_window</field>
			<field name="res_model">term.and.condition</field>
			<field name="view_id" ref="verts_v15_basic_masters.term_and_condition_tree_view" />
			<field name="view_mode">list,form</field>
		</record>

	</data>
</odoo>