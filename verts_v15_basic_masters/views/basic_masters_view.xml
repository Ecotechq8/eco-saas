            <field name="type">ir.actions.act_window</field>
            <field name="res_model">res.state.zone</field>
            <field name="view_id" ref="zone_master_tree_view"/>
            <field name="view_mode">tree,form</field>
        </record>

        <!-- ****************************** Zone/Circle *********************************** -->
        <!-- ********** Zone/Circle tree view ********** -->
        <record id="district_master_tree_view" model="ir.ui.view">
            <field name="name">District</field>
            <field name="model">res.zone.district</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="country_id"/>
                    <field name="state_id"/>
                    <field name="zone_id"/>
                </list>
            </field>
        </record>

        <!-- ********** Zone/circle form view ********** -->
        <record id="district_basic_master_form_view" model="ir.ui.view">
            <field name="name">District</field>
            <field name="model">res.zone.district</field>
            <field name="arch" type="xml">
                <form string="District">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="country_id"/>
                            <field name="state_id"/>
                            <field name="zone_id"/>
