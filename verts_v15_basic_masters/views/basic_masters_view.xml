                    </sheet>
                </form>
            </field>
        </record>

        <!-- ********** Action Point of Stuffing ********** -->
        <record id="action_point_of_stuffing" model="ir.actions.act_window">
            <field name="name">Point of Stuffing</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">point.of.stuffing</field>
            <field name="view_id" ref="point_of_stuffing_tree_view"/>
            <field name="view_mode">tree,form</field>
        </record>

        <!--	Industry Master Tree view	-->
        <record id="industry_tree_view" model="ir.ui.view">
            <field name="name">res_industry_tree</field>
            <field name="model">res.industry</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                    <field name="name" required="1"/>
                </list>
            </field>
        </record>

        <record id="action_res_industry" model="ir.actions.act_window">
            <field name="name">Industry</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">res.industry</field>
<!--            <field name="view_type">form</field>-->
            <field name="view_id" ref="industry_tree_view"/>
