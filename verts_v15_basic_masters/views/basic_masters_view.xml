            <field name="model">res.state.zone</field>
            <field name="arch" type="xml">
                <form string="Zone">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="country_id"/>
                            <field name="state_id" domain="[('country_id','=',country_id)]"/>
