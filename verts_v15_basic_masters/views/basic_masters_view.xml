            <field name="type">ir.actions.act_window</field>
            <field name="res_model">container.type</field>
            <field name="view_id" ref="container_type_basic_master_tree_view"/>
            <field name="view_mode">tree,form</field>
        </record>

        <!-- ****************************** Zone/Circle *********************************** -->
        <!-- ********** Zone/Circle tree view ********** -->
        <record id="zone_master_tree_view" model="ir.ui.view">
