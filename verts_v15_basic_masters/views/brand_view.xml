<odoo>
	<data>
        <!-- Brand Category Form View -->
        <record id="view_brand_cat_form" model="ir.ui.view">
            <field name="name">Brand Category</field>
            <field name="model">brand.category</field>
            <field name="arch" type="xml">
                <form string="Brand Category">
                    <sheet>
                        <group>
                            <field name="name" />
                            <field name="brand_category_code" />
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="view_brand_cat_trees">
                <field name="name">Brand Category</field>
                <field name="model">brand.category</field>
                <field name="type">list</field>
                <field name="arch" type="xml">
                    <list>
                        <field name="brand_category_code" />
                        <field name="name"/>
                    </list>
                </field>
        </record>

        <record id="view_brand_cat_actions" model="ir.actions.act_window">
                <field name="name">Brand Category</field>
                <field name="type">ir.actions.act_window</field>
                <field name="res_model">brand.category</field>
                <field name="view_mode">list,form</field>
                <field name="view_id" ref="verts_v15_basic_masters.view_brand_cat_trees"/>
        </record>

        <!-- Brand Form View -->
        <record id="view_brand_form" model="ir.ui.view">
            <field name="name">Brands</field>
            <field name="model">brand</field>
            <field name="arch" type="xml">
                <form string="Brands">
                    <sheet>
                        <group>
                            <field name="brand_code" />
                            <field name="name" />
                            <field name="brand_category_id" />
                            <field name="brand_category_code" />
                            <field name="applicable_to" />
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="view_brand_trees">
            <field name="name">Brands</field>
            <field name="model">brand</field>
            <field name="type">list</field>
            <field name="arch" type="xml">
                <list>
                    <field name="brand_code" />
                    <field name="name" />
                    <field name="brand_category_id" />
                    <field name="brand_category_code" />
                    <field name="applicable_to" />
                </list>
            </field>
        </record>

        <record id="view_brand_actions" model="ir.actions.act_window">
            <field name="name">Brands</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">brand</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="verts_v15_basic_masters.view_brand_trees"/>
        </record>
    </data>
</odoo>
