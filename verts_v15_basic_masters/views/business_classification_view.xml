<odoo>
	<data>
        <!-- Industry Vertical Form View -->
        <record id="view_industry_vertical_form" model="ir.ui.view">
            <field name="name">Industry Vertical</field>
            <field name="model">industry.vertical</field>
            <field name="arch" type="xml">
                <form string="Industry Vertical">
                    <sheet>
                        <group>
                            <field name="name" />
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="view_industry_vertical_tree">
                <field name="name">Industry Vertical</field>
                <field name="model">industry.vertical</field>
                <field name="type">list</field>
                <field name="arch" type="xml">
                    <list>
                        <field name="name"/>
                    </list>
                </field>
        </record>

        <record id="view_industry_vertical_actions" model="ir.actions.act_window">
                <field name="name">Industry Vertical</field>
                <field name="type">ir.actions.act_window</field>
                <field name="res_model">industry.vertical</field>
                <field name="view_mode">list,form</field>
                <field name="view_id" ref="verts_v15_basic_masters.view_industry_vertical_tree"/>
        </record>

        <!-- Source Form View -->
        <record id="view_source_form" model="ir.ui.view">
            <field name="name">Source</field>
            <field name="model">source</field>
            <field name="arch" type="xml">
                <form string="Source">
                    <sheet>
                        <group>
                            <field name="name" />
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="view_source_tree">
            <field name="name">Source</field>
            <field name="model">source</field>
            <field name="type">list</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                </list>
            </field>
        </record>

        <record id="view_source_actions" model="ir.actions.act_window">
            <field name="name">Source</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">source</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="verts_v15_basic_masters.view_source_tree"/>
        </record>
    </data>
</odoo>