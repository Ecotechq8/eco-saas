<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>

		<!-- Supplier Category -->

		<record id="view_partner_categories_filter" model="ir.ui.view">
			<field name="name">Customer Categories</field>
			<field name="model">partner.categories</field>
			<field name="priority" eval="8" />
			<field name="arch" type="xml">
				<search string="Supplier Categories">
					<field name="name" />
<!--					<field name="account_receivable" />-->
<!--					<field name="account_payable" />-->
					<field name="prefix" />
					<field name="suffix" />
					<field name="sequence_size" />
					<newline />
					<group expand="0" string="Group By...">
						<filter name="supp_cat_filter" string="Name" domain="[]" context="{'group_by':'name'}" />
					</group>
				</search>
			</field>
		</record>

		<record model="ir.ui.view" id="partner_categories_trees">
			<field name="name">Partner Categories</field>
			<field name="model">partner.categories</field>
			<field name="type">list</field>
			<field name="arch" type="xml">
				<list>
					<field name="name" />
<!--					<field name="account_receivable" />-->
<!--					<field name="account_payable" />-->
					<field name="prefix" />
					<field name="suffix" />
					<field name="sequence_size" />
				</list>
			</field>
		</record>
		<record model="ir.ui.view" id="partner_categories_form">
			<field name="name">Partner Categories</field>
			<field name="model">partner.categories</field>
			<field name="type">form</field>
			<field name="arch" type="xml">
				<form string='Partners Type'>
					<group>
						<field name="name" />
						<field name="sequence_size" />
						<field name="prefix" />
						<field name="suffix" />
<!--						<field name="account_receivable" />-->
<!--						<field name="account_payable" />-->
						<field name="type" />
					</group>
				</form>
			</field>
		</record>

		<record id="supplier_categories_actions" model="ir.actions.act_window">
			<field name="name">Supplier Categories</field>
			<field name="res_model">partner.categories</field>
			<field name="view_mode">kanban,list,form</field>
			<field name="domain">[('type','=','supplier')]</field>
			<field name="context">{'default_type': 'supplier'}</field>
			<field name="view_id" ref="view_partner_categories_filter" />
		</record>



