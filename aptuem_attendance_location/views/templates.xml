<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_location" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.hr.attendance.location</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="82"/>
        <field name="inherit_id" ref="hr_attendance.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//block[@name='overtime_settings']" position="after">

                <block title="Allowed Attendance Locations"
                       name="company_locations">

                    <setting string="Locations"
                             help="Define allowed locations for employee check-in and check-out.">

                        <field name="attendance_location_ids"
                               context="{'default_company_id': company_id}">

                            <list editable="bottom">
                                <field name="name"/>
                                <field name="latitude"/>
                                <field name="longitude"/>
                            </list>

                        </field>

                    </setting>

                </block>

            </xpath>

        </field>
    </record>


    <!-- ============================= -->
    <!-- List View -->
    <!-- ============================= -->
    <record id="view_company_attendance_location_list" model="ir.ui.view">
        <field name="name">company.attendance.location.list</field>
        <field name="model">company.attendance.location</field>
        <field name="arch" type="xml">
            <list string="Attendance Locations">
                <field name="name"/>
                <field name="latitude"/>
                <field name="longitude"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <!-- ============================= -->
    <!-- Form View -->
    <!-- ============================= -->
    <record id="view_company_attendance_location_form" model="ir.ui.view">
        <field name="name">company.attendance.location.form</field>
        <field name="model">company.attendance.location</field>
        <field name="arch" type="xml">
            <form string="Attendance Location">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="latitude"/>
                        <field name="longitude"/>
                        <field name="company_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================= -->
    <!-- Action -->
    <!-- ============================= -->
    <record id="action_company_attendance_location" model="ir.actions.act_window">
        <field name="name">Attendance Locations</field>
        <field name="res_model">company.attendance.location</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ============================= -->
    <!-- Menu Item -->
    <!-- ============================= -->
    <menuitem id="menu_company_attendance_location"
              name="Attendance Locations"
              parent="hr_attendance.menu_hr_attendance_root"
              action="action_company_attendance_location"
              sequence="50"/>
</odoo>