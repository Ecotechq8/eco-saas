<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_location" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.hr.attendance.location</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="82"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Attendances"
                     string="Attendances"
                     name="hr_attendance"
                     groups="hr_attendance.group_hr_attendance_manager">

                    <block title="Allowed Attendance Locations"
                           name="company_locations">

                        <setting string="Locations"
                                 help="Define all allowed locations for employee check-in and check-out.">

                            <field name="attendance_location_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="latitude"/>
                                    <field name="longitude"/>
                                </tree>
                            </field>

                        </setting>

                    </block>

                </app>
            </xpath>
        </field>
    </record>
</odoo>