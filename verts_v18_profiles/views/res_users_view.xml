<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Users -->
        <!-- Add widget selection to choose a profile to apply -->
        <record id="view_res_user_form" model="ir.ui.view">
            <field name="name">res.users.form</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="mode">primary</field>
            <field name="priority">10</field>
            <field name="arch" type="xml">
                <data>
                    <xpath expr="//div/group/field[@name='partner_id']" position="after">
                        <field name="user_profile_id" widget="selection"/>
                    </xpath>
                    <xpath expr="//page[@name='account_security']" position="after">
                        <page string="History">
                            <field name="history_lines">
                                <list>
                                    <field name="updated_date"/>
                                    <field name="updated_by"/>
                                    <field name="text"/>
                                    <field name="old_value"/>
                                    <field name="new_value"/>
                                </list>
                            </field>
                        </page>
                    </xpath>
                </data>
            </field>
        </record>
        <record id="base.action_res_users" model="ir.actions.act_window">
            <field name="domain" eval="[('id', '!=', ref('base.user_admin')), ('is_user_profile', '=', False)]"/>
        </record>
        <record id="base.action_res_users_view2" model="ir.actions.act_window.view">
            <field name="view_id" ref="view_res_user_form"/>
        </record>
        <record id="view_users_tree" model="ir.ui.view">
            <field name="name">res.users.list</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_tree"/>
            <field name="arch" type="xml">
                <field name="login" position="after">
                    <field name="user_profile_id" invisible="context.get('is_user_profile')"/>
                </field>
            </field>
        </record>

        <!-- Profiles -->
        <!-- Add page for technical profile configuration-->

        <record id="view_user_profile_form" model="ir.ui.view">
            <field name="name">res.users.form.profile</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="mode">primary</field>
            <field name="priority">10</field>
            <field name="arch" type="xml">
                <data>
                    <field name="name" position="attributes">
                        <attribute name="placeholder">Profile ...</attribute>
                    </field>
                    <field name="partner_id" position="attributes">
                        <attribute name="invisible">1</attribute>
                    </field>
                    <label for="login" position="attributes">
                        <attribute name="invisible">1</attribute>
                    </label>
                    <field name="login" position="attributes">
                        <attribute name="invisible">1</attribute>
                        <attribute name="required">0</attribute>
                    </field>
                    <!-- Hide the Access Rights page -->
                    <xpath expr="//page[@name='access_rights']" position="attributes">
                        <attribute name="invisible">1</attribute>
                    </xpath>
                    <!-- Hide the Preferences page -->
                    <xpath expr="//page[@name='preferences']" position="attributes">
                        <attribute name="invisible">1</attribute>
                    </xpath>
                    <!-- Hide the Account Security page -->
                    <xpath expr="//page[@name='account_security']" position="attributes">
                        <attribute name="invisible">1</attribute>
                    </xpath>
                    <!-- Add Configuration page for profile settings -->
                    <xpath expr="//page[@name='account_security']" position="after">
                        <page string="Configuration">
                            <group>
                                <field name="is_user_profile"/>
                                <field name="is_update_users" invisible="is_user_profile == False"/>
                            </group>
                            <separator string="Linked users"/>
                            <field name="user_ids" nolabel="1" widget="many2many"
                                   context="{'form_view_ref': 'base.view_users_form'}"/>
                            <separator string="Fields to update for linked users"/>
                            <field name="field_ids" nolabel="1"/>
                        </page>
                        <page string="History">
                            <field name="history_lines" readonly="1" force_save="1">
                                <list>
                                    <field name="updated_date"/>
                                    <field name="updated_by"/>
                                    <field name="text"/>
                                    <field name="old_value"/>
                                    <field name="new_value"/>
                                </list>
                            </field>
                        </page>
                    </xpath>
                </data>
            </field>
        </record>
        <record id="action_res_user_profiles" model="ir.actions.act_window">
            <field name="name">User Profiles</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">res.users</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="base.view_users_tree"/>
            <field name="search_view_id" ref="base.view_users_search"/>
            <field name="domain" eval="[('id', '!=', ref('base.user_admin')), ('is_user_profile', '=', True)]"/>
            <field name="context">{'active_test': False, 'default_is_user_profile': True}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a user profile
                </p>
            </field>
        </record>
        <record id="action_res_user_profiles_tree_view" model="ir.actions.act_window.view">
            <field eval="1" name="sequence"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="base.view_users_tree"/>
            <field name="act_window_id" ref="action_res_user_profiles"/>
        </record>
        <record id="action_res_user_profiles_form_view" model="ir.actions.act_window.view">
            <field eval="2" name="sequence"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_user_profile_form"/>
            <field name="act_window_id" ref="action_res_user_profiles"/>
        </record>

        <menuitem action="action_res_user_profiles" id="menu_action_res_user_profiles" parent="base.menu_users"
                  sequence="40"/>

        <!-- Super Admin -->
        <!-- Hide Create button for Super Admin menu -->

        <record id="view_admin_form" model="ir.ui.view">
            <field name="name">res.users.form</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="mode">primary</field>
            <field name="arch" type="xml">
                <data>
                    <xpath expr="//form" position="attributes">
                        <attribute name="create">false</attribute>
                    </xpath>
                </data>
            </field>
        </record>

        <!-- Update domain on std user -->
        <record id="base.action_res_users" model="ir.actions.act_window">
            <field name="name">Users</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">res.users</field>
            <field name="view_mode">list,kanban,form</field>
            <field name="view_id" ref="view_users_tree"/>
            <field name="domain">[('is_user_profile', '=', False)]</field>
            <field name="search_view_id" ref="base.view_users_search"/>
            <field name="context">{'search_default_no_share': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new user
                </p>
                <p>
                    Create and manage users that will connect to the system. Users can be deactivated should
                    there be a period of time during which they will/should not connect to the system. You can assign them
                    groups in order to give them specific access to the applications they need to use in the system.
                </p>
            </field>
        </record>

    </data>
</odoo>
