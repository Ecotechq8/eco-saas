<?xml version="1.0"?>
<odoo>
	<record id="group_assign_wiz_form" model="ir.ui.view">
		<field name="name">group.assign.form</field>
		<field name="model">group.assign</field>
		<field name="arch" type="xml">
			<form string="Assign">
				<group>
					<field name="users_id" required="1" widget="many2many_tags"
						domain="[('is_user_profile', '=', True),('active', '=', False)]" options="{'no_open': True, 'no_create': True}"/>
				</group>
				<footer>
					<button name="group_assign_action" string="Assign" type="object" class="btn
						btn-secondary"/>
					<button string="Cancel" class="btn btn-secondary" special="cancel"/>
				</footer>
			</form>
		</field>
	</record>

	<record id="group_assign_action" model="ir.actions.act_window">
		<field name="name">Group Assign</field>
		<field name="type">ir.actions.act_window</field>
		<field name="res_model">group.assign</field>
		<field name="view_mode">form</field>
		<field name="view_id" ref="group_assign_wiz_form"/>
		<field name="target">new</field>
	</record>

</odoo>
