<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard View -->
    <record id="view_data_cleanup_wizard_form" model="ir.ui.view">
        <field name="name">data.cleanup.wizard.form</field>
        <field name="model">data.cleanup.wizard</field>
        <field name="arch" type="xml">
            <form string="Delete All Transactions">
                <group>
                    <field name="delete_all"/>
                </group>
                <group string="Select Modules to Clean" invisible="delete_all">
                    <group>
                        <field name="delete_purchase"/>
                        <field name="delete_sales"/>
                        <field name="delete_inventory"/>
                    </group>
                    <group>
                        <field name="delete_projects"/>
                        <field name="delete_accounting"/>
                    </group>
                </group>
                <div class="alert alert-warning" role="alert" style="margin: 10px 0;">
                    <strong>WARNING:</strong> This action will permanently delete all selected transaction data.
                    Master data (products, partners, employees, etc.) will be preserved.
                    <br/>This operation CANNOT be undone!
                </div>
                <footer>
                    <button name="action_delete_all_transactions" 
                            string="Delete Transactions" 
                            type="object" 
                            class="btn-danger"
                            confirm="This action will delete all selected transactions. This CANNOT be undone. Are you sure you want to proceed?"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action Window -->
    <record id="action_data_cleanup_wizard" model="ir.actions.act_window">
        <field name="name">Delete All Transactions</field>
        <field name="res_model">data.cleanup.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu Items - referencing action from same file -->
    <menuitem id="menu_data_cleanup"
              name="Delete All Transactions"
              parent="stock.menu_stock_inventory_control"
              action="action_data_cleanup_wizard"
              sequence="100"
              groups="stock.group_stock_manager"/>

    <menuitem id="menu_data_cleanup_settings"
              name="Data Cleanup"
              parent="base.menu_administration"
              action="action_data_cleanup_wizard"
              sequence="99"
              groups="base.group_system"/>
</odoo>
