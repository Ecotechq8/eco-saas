<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>
    <template id="picking_professional_external_layout">
        <!-- Multicompany -->
        <t t-if="o and 'company_id' in o">
            <t t-set="company" t-value="o.company_id"></t>
        </t>
        <t t-if="not o or not 'company_id' in o">
            <t t-set="company" t-value="res_company"></t>
        </t>
    
        <t t-call="verts_v15_print_template.picking_professional_header"/>
        <t t-out="0" />
        <t t-call="report.external_layout_footer"/>
    </template>
    <template id="picking_professional_header">
        <div class="header">
            <table border="0" cellspacing="0" cellpadding="0" width="100%">
            <tbody>
                <tr>
                    <td>
                        <center>
                        <table width="100%" border="0" cellspacing="0" cellpadding="0" style="padding:0px 20px 20px 20px; margin:0; font-family: Arial,Helvetica, sans-serif; background:#fff; text-transform:uppercase; line-height:20px;">
                            <tr>
                                <td valign="top" colspan="4" align="left" t-attf-style="color:#4D4D4F; font-size:12px; padding:9px 0px 9px 0px;  border-bottom:1px solid #{o.company_id and o.company_id.theme_color or '#000000'};">
                                    <table width="100%" border="0" cellspacing="0" cellpadding="0" >
                                        <tr>
                                            <td valign="top" align="left" style="color:#4D4D4F; font-size:12px; padding:0 0px; margin:0 ">
                                                <table width="100%" border="0" cellspacing="0" cellpadding="0" >
                                                    <tr>
                                                        <td valign="middle" align="left" style="color:#4D4D4F; font-size:12px; padding:0px; margin:0;">
                                                        <img t-if="o.company_id.logo" t-att-src="'data:image/png;base64,%s' % o.company_id.invoice_logo or o.company_id.logo" style="max-height: 80px;"/>
                                                        </td>
                                                        <td  valign="middle" align="center" style=" font-size:12px; padding:0px; margin:0;">
                                                            <img t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', o.name, 600, 100)" style="width:190px;height:35px;"/>
                                                        </td>
                                                    </tr>
                                                </table>
                                            </td>
                                            <td valign="top" align="right" style="font-size:12px; padding:0; width:50%;">
                                                <h5 t-attf-style="background-color: #{o.company_id and o.company_id.theme_color or '#000000'}; color: #{o.company_id and o.company_id.theme_text_color or '#000000'}; text-align:center;font-weight:bold; text-transform:uppercase; padding: 60px 0px;width: 150px;">Picking Operations:<br/><span t-field="o.name"/></h5>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>
                        </center>
                    </td>
                </tr>
            </tbody>
        </table>
        </div>
    </template>
    <template id="template_footer">
        <div class="footer">
            <div class="col-md-12 text-center" t-attf-style="color: #{'#ffffff'};">
                <span t-field="company.website"/>
            </div>
        </div>      
    </template>
    
    <template id="report_picking_professional_main">
        <t t-call="verts_v15_print_template.picking_professional_external_layout">
            <t t-set="o" t-value="o.with_context({'lang':o.partner_id.lang})" />
            <div class="page">
                <div class="oe_structure"/>
                <br/>
                <br/>
                <br/>
                <br/>
                <table border="0" cellspacing="0" cellpadding="0" width="100%">
            <tbody>
                <tr>
                    <td>
                        <center>
                        <table width="100%" border="0" cellspacing="0" cellpadding="0" style="font-size:12px;padding:0px 20px 20px 20px; margin:0; font-family: Arial,Helvetica, sans-serif; background:#fff; line-height:20px;">
                            <tr>
                                <td valign="top" align="left" t-attf-style="color:#4D4D4F; font-size:12px; padding:9px 0px 9px 0px; border-bottom:1px solid #{o.company_id and o.company_id.theme_color or '#000000'};width:50%;">
                                    <t t-if="o.company_id and o.company_id.is_company_bold">
                                    <h2 style="text-transform:capitalize; font-size :13px; padding:0px; margin:0;"><b><span t-attf-style="color: #{o.company_id and o.company_id.company_color or '#ffffff'};" t-field="o.company_id.partner_id"/></b></h2>
                                    </t>
                                    <t t-if="not o.company_id.is_company_bold">
                                    <h2 style="text-transform:capitalize; font-size :13px; padding:0px; margin:0;"><span t-attf-style="color: #{o.company_id and o.company_id.company_color or '#ffffff'};" t-field="o.company_id.partner_id"/></h2>
                                    </t>
                                    <div t-attf-style="color: #{o.company_id and o.company_id.company_address_color or '#ffffff'};">
                                        <span t-out="o._get_street(o.company_id.partner_id)"/><br/>
                                        <span t-out="o._get_address_details(o.company_id.partner_id)"/>
                                    </div>
                                    <t t-if="o.company_id.partner_id.mobile"><strong t-attf-style="color: #{o.company_id and o.company_id.company_address_color or '#ffffff'};">Mobile: </strong><span t-attf-style="color: #{o.company_id and o.company_id.company_address_color or '#ffffff'};" t-field="o.company_id.partner_id.mobile"/><br/></t>
                                    <t t-if="o.company_id.partner_id.email"><strong t-attf-style="color: #{o.company_id and o.company_id.company_address_color or '#ffffff'};">Email: </strong><span t-attf-style="color: #{o.company_id and o.company_id.company_address_color or '#ffffff'};" t-field="o.company_id.partner_id.email"/></t>
                                </td>
                                <td valign="top" align="left" t-attf-style="padding:15px 0px 15px 0px; width:50%; line-height:20px; border-bottom:1px solid #{o.company_id and o.company_id.theme_color or '#000000'};">
                                    <p t-attf-style="text-transform:capitalize; color: #{o.company_id and o.company_id.theme_color or '#ffffff'}; font-size:14px; font-weight:bold;margin:0; margin-bottom:5px;">Picking Operations:</p>
                                    <div t-if="o.picking_type_id.code=='incoming' and o.partner_id">
                                        <span><strong>Vendor Address:</strong></span>
                                    </div>
                                    <div t-if="o.picking_type_id.code=='internal' and o.partner_id">
                                        <span><strong>Warehouse Address:</strong></span>
                                    </div>
                                    <div t-if="o.picking_type_id.code=='outgoing' and o.partner_id">
                                        <span><strong>Customer Address:</strong></span>
                                    </div>
                                    <t t-if="o.company_id and o.company_id.is_customer_bold">
                                        <h1 style="text-transform:capitalize; font-size :13px; padding:0px; margin:0;"><b><span t-attf-style="color: #{o.company_id and o.company_id.customer_color or '#ffffff'};" t-field="o.partner_id"/></b></h1>
                                    </t>
                                    <t t-if="not o.company_id.is_customer_bold">
                                        <h1 style="text-transform:capitalize; font-size :13px; padding:0px; margin:0;"><span t-attf-style="color: #{o.company_id and o.company_id.customer_color or '#ffffff'};" t-field="o.partner_id"/></h1>
                                    </t>
                                    <p t-attf-style="color: #{o.company_id and o.company_id.customer_address_color or '#ffffff'};">
                                        <span t-out="o._get_street(o.partner_id)"/><br/>
                                        <span t-out="o._get_address_details(o.partner_id)"/><br/>
                                        <t t-if="o.partner_id.mobile"><strong t-attf-style="color: #{o.company_id and o.company_id.customer_address_color or '#ffffff'};">Mobile: </strong><span t-field="o.partner_id.mobile"/><br/></t>
                                        <t t-if="o.partner_id.email"><strong t-attf-style="color: #{o.company_id and o.company_id.customer_address_color or '#ffffff'};">Email: </strong><span t-field="o.partner_id.email"/></t>
                                    </p>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="2" t-attf-style="border-top:1px solid #{o.company_id and o.company_id.theme_color or '#000000'}; padding:10px;"></td>
                            </tr>
                            <tr>
                                <td colspan="4">
                                <table width="100%" border="0" cellspacing="0" cellpadding="0" t-attf-style="color:#fff; font-size:12px; border: 1px solid #{o.company_id and o.company_id.theme_color or '#000000'};">
                                    <tr t-attf-style="color: #{o.company_id and o.company_id.theme_text_color or '#000000'}; background-color: #{o.company_id and o.company_id.theme_color or '#000000'};">
                                        <td t-attf-style="padding:9px 15px; font-weight:bold; color: #{o.company_id and o.company_id.theme_text_color or '#000000'};">
                                            <span>Picking No # </span><br/>
                                            <span t-field="o.name"/>
                                        </td>
                                        <td t-attf-style="padding:5px 15px; font-weight:bold; color: #{o.company_id and o.company_id.theme_text_color or '#000000'};">
                                            <strong>Order (Origin)</strong><br/>
                                            <span t-field="o.picking_type_id"/>
                                        </td>
                                        <td t-attf-style="padding:5px 15px; font-weight:bold; color: #{o.company_id and o.company_id.theme_text_color or '#000000'};">
                                            <strong>State</strong><br/>
                                            <span t-field="o.state"/>
                                        </td>
                                        <td t-attf-style="padding:5px 15px; font-weight:bold; color: #{o.company_id and o.company_id.theme_text_color or '#000000'};">
                                            <strong>Commitment Date</strong><br/>
                                            <span t-field="o.date"/>
                                        </td>
                                        <td name="td_sched_date_h" t-attf-style="padding:5px 15px; font-weight:bold; color: #{o.company_id and o.company_id.theme_text_color or '#000000'};">
                                            <strong><span class="text-left">Scheduled Date</span></strong><br/>
                                            <span t-field="o.min_date"/>
                                        </td>
                                        <td t-if="o._check_delivery_installed() and o.picking_type_id.code == 'outgoing'" t-attf-style="padding:5px 15px; font-weight:bold; color: #{o.company_id and o.company_id.theme_text_color or '#000000'};">
                                            <strong><span class="text-left">Carrier</span></strong><br/>
                                            <span t-field="o.carrier_id"/>
                                        </td>
                                        <td t-if="o._check_delivery_installed()" t-attf-style="padding:5px 15px; font-weight:bold; color: #{o.company_id and o.company_id.theme_text_color or '#000000'};">
                                            <strong><span class="text-left">Weight</span></strong><br/>
                                            <span t-field="o.weight"/>
                                        </td>
                                    </tr>
                                    </table>
                                    <br/>
                                    </td>
                                    </tr>
                                    <tr>
                                        <td colspan="2" t-attf-style="border-bottom:1px solid #{o.company_id and o.company_id.theme_color or '#000000'}; padding:0px;"></td>
                                    </tr>
                                    <tr>
                                        <td colspan="2" valign="top" align="left" style=" font-size:12px; padding:20px 0px 0 0; fnt-weight:bold; ">
                                            <table t-if="o.pack_operation_ids" class="table" width="100%" cellspacing="0" cellpadding="0" style="border:0.5px solid #ccc;  border-collapse: collapse; padding:15px; border-bottom:1px solid #ccc;">
                                                <tr t-attf-style="background-color: #{o.company_id and o.company_id.theme_color or '#000000'}; color: #{o.company_id and o.company_id.theme_text_color or '#000000'};">
                                                    <td  align="center" width="8%" t-attf-style="padding:5px 10px; color: #{o.company_id and o.company_id.theme_text_color or '#000000'}; border:1px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; border-right:0px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; font-weight:bold;">Sr.</td>
                                                    <td align="left" width="52%" t-attf-style="padding:5px 10px; color: #{o.company_id and o.company_id.theme_text_color or '#000000'}; border:1px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; border-right:0px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; font-weight:bold;">Product</td>
                                                    <td align="right" width="20%" t-attf-style="padding:5px 10px; color: #{o.company_id and o.company_id.theme_text_color or '#000000'}; border:1px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; border-right:0px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; font-weight:bold;">Quantity</td>
                                                    <td t-if="o.picking_type_id.code != 'incoming'" align="right" width="14%" t-attf-style="padding:5px 10px; color: #{o.company_id and o.company_id.theme_text_color or '#000000'}; border:1px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; border-right:0px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; font-weight:bold;">Source</td>
                                                    <td align="center" width="15%" t-attf-style="padding:5px 10px; color: #{o.company_id and o.company_id.theme_text_color or '#000000'}; border:1px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; border-right:0px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; font-weight:bold;">Barcode</td>
                                                    <td t-if="o.picking_type_id.code != 'outgoing'" align="right" width="15%" t-attf-style="padding:5px 10px; color: #{o.company_id and o.company_id.theme_text_color or '#000000'}; border:1px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; border-right:0px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; font-weight:bold;">Destination</td>
                                                </tr>
                                                <t t-foreach="o.pack_operation_ids" t-as="pack_operation">
                                                    <t t-if="pack_operation_odd">
                                                        <tr t-att-style="'background-color: '+ o.company_id.even_party_color or o.company_id.even_party_color ">
                                                            <td class="text-center" align="left" t-att-style="'padding:5px 10px; border:0.5px solid #ccc !important; border-right:0px solid #ccc !important; color: %s;' % (o.company_id.text_color)">
                                                               <span t-out="pack_operation_index+1"/>
                                                            </td>
                                                            <td class="text-left" align="left" t-att-style="'padding:5px 10px; border:0.5px solid #ccc !important; border-right:0px solid #ccc !important; color: %s;' % (o.company_id.text_color)">
                                                                <span t-field="pack_operation.product_id"/>
                                                                <t t-if="not pack_operation.product_id and pack_operation.package_id">
                                                                    <span  t-field="pack_operation.package_id"/>
                                                                </t>
                                                            </td>
                                                            <td class="text-right" align="right" t-att-style="'padding:5px 10px; border:0.5px solid #ccc !important; border-right:0px solid #ccc !important; color: %s;' % (o.company_id.text_color)">
                                                                <span t-field="pack_operation.product_qty"/>
                                                                <span t-field="pack_operation.product_uom_id" groups="product.group_uom"/>
                                                            </td>
                                                            <td t-if="o.picking_type_id.code != 'incoming'" class="text-right" align="center" t-att-style="'padding:5px 10px; border:0.5px solid #ccc !important; border-right:0px solid #ccc !important; color: %s;' % (o.company_id.text_color)">
                                                                <span t-field="pack_operation.location_id"/>
                                                                <span t-if="pack_operation.package_id">:</span>
                                                                <span t-field="pack_operation.package_id"/>
                                                            </td>
                                                            <td class="text-right" align="center" t-att-style="'padding:5px 10px; border:0.5px solid #ccc !important; border-right:0px solid #ccc !important; color: %s;' % (o.company_id.text_color)">
                                                                <span t-if="pack_operation.product_id and pack_operation.product_id.barcode">
                                                                    <img t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', pack_operation.product_id.barcode, 600, 100)" style="width:300px;height:50px"/>
                                                                </span>
                                                                <span t-if="pack_operation.package_id and not pack_operation.product_id">
                                                                    <img t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', pack_operation.package_id.name, 600, 100)" style="width:300px;height:50px"/>
                                                                </span>
                                                                <table class="table table-condensed" t-if="pack_operation.pack_lot_ids">
                                                                    <thead>
                                                                        <tr><th>Lot</th><th>Qty</th></tr>
                                                                    </thead>
                                                                    <tr t-foreach="pack_operation.pack_lot_ids" t-as="packlot">
                                                                        <td>
                                                                            <span t-field="packlot.lot_id"/>
                                                                            <t t-if="not packlot.lot_id">
                                                                                <span t-field="packlot.lot_name"/>
                                                                            </t>
                                                                        </td>
                                                                        <td>
                                                                            <span t-field="packlot.qty"/> <t t-if="o.picking_type_id.use_existing_lots and o.state!='done'"> / <span t-field="packlot.qty_todo"/></t>
                                                                        </td>
                                                                    </tr>
                                                                </table>
                                                            </td>
                                                            <td t-if="o.picking_type_id.code != 'outgoing'" class="text-right" align="right" t-att-style="'padding:5px 10px; border:0.5px solid #ccc !important; border-right:0px solid #ccc !important; color: %s;' % (o.company_id.text_color)">
                                                                <span t-field="pack_operation.location_dest_id"/>
                                                                <span t-if="pack_operation.result_package_id">:</span>
                                                                <span t-field="pack_operation.result_package_id"/>
                                                            </td>
                                                        </tr>
                                                    </t>
                                                    <t t-if="pack_operation_even">
                                                        <tr t-att-style="'background-color: '+ o.company_id.odd_party_color or o.company_id.odd_party_color ">
                                                            <td class="text-center" align="left" t-att-style="'padding:5px 10px; border:0.5px solid #ccc !important; border-right:0px solid #ccc !important; color: %s;' % (o.company_id.text_color)">
                                                               <span t-out="pack_operation_index+1"/>
                                                            </td>
                                                            <td class="text-left" align="left" t-att-style="'padding:5px 10px; border:0.5px solid #ccc !important; border-right:0px solid #ccc !important; color: %s;' % (o.company_id.text_color)">
                                                                <span t-field="pack_operation.product_id"/>
                                                                <t t-if="not pack_operation.product_id and pack_operation.package_id">
                                                                    <span  t-field="pack_operation.package_id"/>
                                                                </t>
                                                            </td>
                                                            <td class="text-right" align="right" t-att-style="'padding:5px 10px; border:0.5px solid #ccc !important; border-right:0px solid #ccc !important; color: %s;' % (o.company_id.text_color)">
                                                                <span t-field="pack_operation.product_qty"/>
                                                                <span t-field="pack_operation.product_uom_id" groups="product.group_uom"/>
                                                            </td>
                                                            <td t-if="o.picking_type_id.code != 'incoming'" class="text-right" align="center" t-att-style="'padding:5px 10px; border:0.5px solid #ccc !important; border-right:0px solid #ccc !important; color: %s;' % (o.company_id.text_color)">
                                                                <span t-field="pack_operation.location_id"/>
                                                                <span t-if="pack_operation.package_id">:</span>
                                                                <span t-field="pack_operation.package_id"/>
                                                            </td>
                                                            <td class="text-right" align="center" t-att-style="'padding:5px 10px; border:0.5px solid #ccc !important; border-right:0px solid #ccc !important; color: %s;' % (o.company_id.text_color)">
                                                                <span t-if="pack_operation.product_id and pack_operation.product_id.barcode">
                                                                    <img t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', pack_operation.product_id.barcode, 600, 100)" style="width:300px;height:50px"/>
                                                                </span>
                                                                <span t-if="pack_operation.package_id and not pack_operation.product_id">
                                                                    <img t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('Code128', pack_operation.package_id.name, 600, 100)" style="width:300px;height:50px"/>
                                                                </span>
                                                                <table class="table table-condensed" t-if="pack_operation.pack_lot_ids">
                                                                    <thead>
                                                                        <tr><th>Lot</th><th>Qty</th></tr>
                                                                    </thead>
                                                                    <tr t-foreach="pack_operation.pack_lot_ids" t-as="packlot">
                                                                        <td>
                                                                            <span t-field="packlot.lot_id"/>
                                                                            <t t-if="not packlot.lot_id">
                                                                                <span t-field="packlot.lot_name"/>
                                                                            </t>
                                                                        </td>
                                                                        <td>
                                                                            <span t-field="packlot.qty"/> <t t-if="o.picking_type_id.use_existing_lots and o.state!='done'"> / <span t-field="packlot.qty_todo"/></t>
                                                                        </td>
                                                                    </tr>
                                                                </table>
                                                            </td>
                                                            <td t-if="o.picking_type_id.code != 'outgoing'" class="text-right" align="right" t-att-style="'padding:5px 10px; border:0.5px solid #ccc !important; border-right:0px solid #ccc !important; color: %s;' % (o.company_id.text_color)">
                                                                <span t-field="pack_operation.location_dest_id"/>
                                                                <span t-if="pack_operation.result_package_id">:</span>
                                                                <span t-field="pack_operation.result_package_id"/>
                                                            </td>
                                                        </tr>
                                                    </t>
                                                </t>
                                            </table>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <p t-attf-style="color: #{o.company_id and o.company_id.text_color or '#000000'};" t-if="not o.pack_operation_ids">
                                                You do not have any products reserved for this picking.  Please click the 'Reserve' button
                                                to check if products are available.
                                            </p>
                                        </td>
                                    </tr>
                </table>
                </center>
            </td>
        </tr>
    </tbody>
</table>
                <div class="oe_structure"/>
            </div>
        </t>
    </template>
    
    <template id="report_picking_custom_professional">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="verts_v15_print_template.report_picking_professional_main" t-lang="o.partner_id.lang"/>
            </t>
        </t>
    </template>

</data>
</odoo>