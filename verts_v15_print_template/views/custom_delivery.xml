    <template id="stock.report_deliveryslip">
    <t t-call="web.html_container">
        <t t-set="report_name" t-value="{'report_delivery_custom': 'verts_v15_print_template.report_delivery_custom_main',
                                        'report_delivery_custom_creative': 'verts_v15_print_template.report_delivery_creative_main',
                                        'report_delivery_custom_elegant': 'verts_v15_print_template.report_delivery_elegant_main',
                                        'report_delivery_custom_professional': 'verts_v15_print_template.report_delivery_professional_main',
                                        'report_delivery_custom_exclusive': 'verts_v15_print_template.report_delivery_exclusive_main',
                                        'report_delivery_custom_advanced': 'verts_v15_print_template.report_delivery_advanced_main',}"/>
        <t t-foreach="docs" t-as="o">
            <t t-set="r_name" t-value="o.report_template_id and o.report_template_id.report_name or o.partner_id and o.partner_id.report_delivery_template_id and o.partner_id.report_delivery_template_id.report_name or o.company_id and o.company_id.report_delivery_template_id and o.company_id.report_delivery_template_id.report_name"/>
            <t t-set="real_name" t-value="r_name.split('.')"/>
            <t t-if="o.report_template_id or o.partner_id and o.partner_id.report_delivery_template_id or o.company_id and o.company_id.report_delivery_template_id">
                <!-- <t t-call="#{report_name.get(real_name[1], 'verts_v15_print_template.report_delivery_custom_main')}" t-lang="o.partner_id.lang"/> -->
                <t t-if="r_name == 'verts_v15_print_template.report_delivery_custom'" t-call="verts_v15_print_template.report_delivery_custom_main" t-lang="o.partner_id.lang"/>
                <t t-if="r_name == 'verts_v15_print_template.report_delivery_custom_creative'" t-call="verts_v15_print_template.report_delivery_creative_main" t-lang="o.partner_id.lang"/>
                <t t-if="r_name == 'verts_v15_print_template.report_delivery_custom_elegant'" t-call="verts_v15_print_template.report_delivery_elegant_main" t-lang="o.partner_id.lang"/>
                <t t-if="r_name == 'verts_v15_print_template.report_delivery_custom_professional'" t-call="verts_v15_print_template.report_delivery_professional_main" t-lang="o.partner_id.lang"/>
                <t t-if="r_name == 'verts_v15_print_template.report_delivery_custom_exclusive'" t-call="verts_v15_print_template.report_delivery_exclusive_main" t-lang="o.partner_id.lang"/>
                <t t-if="r_name == 'verts_v15_print_template.report_delivery_custom_advanced'" t-call="verts_v15_print_template.report_delivery_advanced_main" t-lang="o.partner_id.lang"/>
            </t>
        </t>
    </t>
    </template>
    
