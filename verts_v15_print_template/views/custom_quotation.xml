<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>
    <template id="quotation_template_external_layout">
        <!-- Multicompany -->
        <t t-if="o and 'company_id' in o">
            <t t-set="company" t-value="o.company_id"></t>
        </t>
        <t t-if="not o or not 'company_id' in o">
            <t t-set="company" t-value="res_company"></t>
        </t>
    
        <t t-call="verts_v15_print_template.quotation_template_header" />
        <t t-out="0" />
        <t t-call="report.external_layout_footer" />
    </template>
    <template id="quotation_template_header">
        <div class="header">
        <table border="0" cellspacing="0" cellpadding="0" width="100%">
            <tbody>
                <tr>
                    <td>
                        <center>
                        <table width="100%" border="0" cellspacing="0" cellpadding="0" t-attf-style="padding:0px 20px 0px 20px; margin:0; font-family: Arial,Helvetica, sans-serif; background:#fff; line-height:20px; border-bottom:1px solid #{o.company_id and o.company_id.theme_color or '#000000'};">
                            <tr>
                                <td valign="top" colspan="2" align="left" style="color:#4D4D4F; font-size:12px; padding:0 0px;">
                                    <table width="100%" border="0" cellspacing="0" cellpadding="0" >
                                        <tr>
                                            <td valign="middle" align="left" style="color:#4D4D4F; font-size:12px; padding:0 0px; margin:0 ">
                                                <img t-if="o.company_id.logo" t-att-src="'data:image/png;base64,%s' % o.company_id.invoice_logo or company.logo" style="max-height: 80px; margin-top: 22%;"/>
                                            </td>
                                            <td  valign="top" width="570" align="right" style=" font-size:12px; padding: 0 0 25px 0; line-height:16px; padding-top:16px">
                                                <t t-if="o.company_id and o.company_id.is_company_bold">
                                                <h2 style="font-size :13px; padding:0px; margin:0;"><b><span t-attf-style="color: #{o.company_id and o.company_id.company_color or '#ffffff'};" t-field="o.company_id.partner_id"/></b></h2>
                                                </t>
                                                <t t-if="not o.company_id.is_company_bold">
                                                <h2 style="font-size :13px; padding:0px; margin:0;"><span t-attf-style="color: #{o.company_id and o.company_id.company_color or '#ffffff'};" t-field="o.company_id.partner_id"/></h2>
                                                </t>
                                                <!--div t-attf-style="color: #{o.company_id and o.company_id.company_address_color or '#ffffff'};" t-field="o.company_id.partner_id" 
                                                t-field-options='{"widget": "contact", "fields": ["address"], "no_marker": true}'/-->
                                                <div t-attf-style="color: #{o.company_id and o.company_id.company_address_color or '#ffffff'};">
                                                <span t-out="o._get_street(o.company_id.partner_id)"/><br/>
                                                <span t-out="o._get_address_details(o.company_id.partner_id)"/>
                                                </div>
                                                <t t-if="o.company_id.partner_id.mobile"><strong t-attf-style="color: #{o.company_id and o.company_id.company_address_color or '#ffffff'};">Mobile: </strong><span t-attf-style="color: #{o.company_id and o.company_id.company_address_color or '#ffffff'};" t-field="o.company_id.partner_id.mobile"/><br/></t>
                                                <t t-if="o.company_id.partner_id.email"><strong t-attf-style="color: #{o.company_id and o.company_id.company_address_color or '#ffffff'};">Email: </strong><span t-attf-style="color: #{o.company_id and o.company_id.company_address_color or '#ffffff'};" t-field="o.company_id.partner_id.email"/></t>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>
                        </center>
                    </td>
                </tr>
            </tbody>
        </table>
        </div>
    </template>
    
    <template id="report_quotation_main">
        <t t-call="verts_v15_print_template.quotation_template_external_layout">
            <t t-set="o" t-value="o.with_context({'lang':o.partner_id.lang})" />
            <div class="page">
                <div class="oe_structure"/>
            <table border="0" cellspacing="0" cellpadding="0" width="100%">
            <tbody>
                <tr>
                    <td>
                        <center>
                        <br/>
                        <table width="100%" border="0" cellspacing="0" cellpadding="0" style="font-size:12px; padding:0px 20px 20px 20px; margin:0; font-family: Arial,Helvetica, sans-serif; background:#fff; line-height:20px;">
                        <tr style="background-color:#f2f2f2">
                                <td valign="top" align="left" style="padding:15px; width:50%; line-height:18px;">
                                    <strong>Shipping address:</strong>
                                    <t t-if="o.dest_address_id">
                                        <t t-if="o.company_id and o.company_id.is_customer_bold">
                                            <h1 style="text-transform:capitalize; font-size :13px; padding:0px; margin:0;"><b><span t-attf-style="color: #{o.company_id and o.company_id.customer_color or '#ffffff'};" t-field="o.dest_address_id"/></b></h1>
                                        </t>
                                        <t t-if="not o.company_id.is_customer_bold">
                                            <h1 style="text-transform:capitalize; font-size :13px; padding:0px; margin:0;"><span t-attf-style="color: #{o.company_id and o.company_id.customer_color or '#ffffff'};" t-field="o.dest_address_id"/></h1>
                                        </t>
                                        <p t-attf-style="color: #{o.company_id and o.company_id.customer_address_color or '#ffffff'};">
                                            <span t-out="o._get_street(o.dest_address_id)"/><br/>
                                            <span t-out="o._get_address_details(o.dest_address_id)"/><br/>
                                            <t t-if="o.dest_address_id.mobile"><strong t-attf-style="color: #{o.company_id and o.company_id.customer_address_color or '#ffffff'};">Mobile: </strong><span t-field="o.dest_address_id.mobile"/><br/></t>
                                            <t t-if="o.dest_address_id.email"><strong t-attf-style="color: #{o.company_id and o.company_id.customer_address_color or '#ffffff'};">Email: </strong><span t-field="o.dest_address_id.email"/></t>
                                        </p>
                                    </t>
                                    <t t-if="not o.dest_address_id and o.picking_type_id and o.picking_type_id.warehouse_id">
                                        <t t-if="o.company_id and o.company_id.is_customer_bold">
                                            <h1 style="text-transform:capitalize; font-size :13px; padding:0px; margin:0;"><b><span t-attf-style="color: #{o.company_id and o.company_id.customer_color or '#ffffff'};" t-field="o.picking_type_id.warehouse_id.name"/></b></h1>
                                        </t>
                                        <t t-if="not o.company_id.is_customer_bold">
                                            <h1 style="text-transform:capitalize; font-size :13px; padding:0px; margin:0;"><span t-attf-style="color: #{o.company_id and o.company_id.customer_color or '#ffffff'};" t-field="o.picking_type_id.warehouse_id.name"/></h1>
                                        </t>
                                        <p t-attf-style="color: #{o.company_id and o.company_id.customer_address_color or '#ffffff'};">
                                            <span t-out="o._get_street(o.picking_type_id.warehouse_id.partner_id)"/><br/>
                                            <span t-out="o._get_address_details(o.picking_type_id.warehouse_id.partner_id)"/><br/>
                                            <t t-if="o.picking_type_id.warehouse_id.partner_id.mobile"><strong t-attf-style="color: #{o.company_id and o.company_id.customer_address_color or '#ffffff'};">Mobile: </strong><span t-field="o.picking_type_id.warehouse_id.partner_id.mobile"/><br/></t>
                                            <t t-if="o.picking_type_id.warehouse_id.partner_id.email"><strong t-attf-style="color: #{o.company_id and o.company_id.customer_address_color or '#ffffff'};">Email: </strong><span t-field="o.picking_type_id.warehouse_id.partner_id.email"/></t>
                                        </p>
                                    </t>
                                    <t t-if="o.company_id and o.company_id.is_customer_bold">
                                        <h1 style="text-transform:capitalize; font-size :13px; padding:0px; margin:0;"><b><span t-attf-style="color: #{o.company_id and o.company_id.customer_color or '#ffffff'};" t-field="o.partner_id.name"/></b></h1>
                                    </t>
                                    <t t-if="not o.company_id.is_customer_bold">
                                        <h1 style="text-transform:capitalize; font-size :13px; padding:0px; margin:0;"><span t-attf-style="color: #{o.company_id and o.company_id.customer_color or '#ffffff'};" t-field="o.partner_id.name"/></h1>
                                    </t>
                                    <p t-attf-style="color: #{o.company_id and o.company_id.customer_address_color or '#ffffff'};">
                                        <span t-out="o._get_street(o.partner_id)"/><br/>
                                        <span t-out="o._get_address_details(o.partner_id)"/><br/>
                                        <t t-if="o.partner_id.mobile"><strong t-attf-style="color: #{o.company_id and o.company_id.customer_address_color or '#ffffff'};">Mobile: </strong><span t-field="o.partner_id.mobile"/><br/></t>
                                        <t t-if="o.partner_id.email"><strong t-attf-style="color: #{o.company_id and o.company_id.customer_address_color or '#ffffff'};">Email: </strong><span t-field="o.partner_id.email"/></t>
                                    </p>
                                </td>
                                <td  valign="top" align="right" style="font-size:14px; padding:15px; width:50%;">
                                    <table t-attf-style="text-transform:capitalize; font-size:14px; background-color: #{o.company_id and o.company_id.theme_color or '#000000'}; color: #{'#ffffff'};">
                                        <tr>
                                            <td t-attf-style="padding:9px 15px; font-weight:bold; color: #{o.company_id and o.company_id.theme_text_color or '#000000'};">
                                                <span>Request for Quotation # </span>
                                            </td>
                                            <td t-attf-style="text-align:right; font-weight:bold;padding:9px 15px; color: #{o.company_id and o.company_id.theme_text_color or '#000000'};">
                                                <span t-field="o.name"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td t-attf-style="background-color:#f2f2f2; height:4px; color: #{o.company_id and o.company_id.theme_text_color or '#000000'};" colspan="2"/>
                                            <td/>
                                        </tr>
                                        <tr>
                                            <td t-attf-style="padding:5px 15px; font-weight:bold; color: #{o.company_id and o.company_id.theme_text_color or '#000000'};">
                                                <strong t-if="o.state not in ['draft']">Date Ordered:</strong>
                                                <strong t-if="o.state in ['draft']">Quotation Date:</strong>
                                            </td>
                                            <td t-attf-style="text-align:right; padding:5px 15px; color: #{o.company_id and o.company_id.theme_text_color or '#000000'};">
                                                <span t-field="o.date_order"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td t-attf-style="padding:5px 15px; font-weight:bold; color: #{o.company_id and o.company_id.theme_text_color or '#000000'};">
                                                <span class="text-left">Your Order Reference</span>
                                            </td>
                                            <td t-attf-style="text-align:right;padding:5px 15px; color: #{o.company_id and o.company_id.theme_text_color or '#000000'};">
                                                <span t-field="o.partner_ref"/>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                                </tr>
                <tr>
                    <td colspan="2" t-attf-style="border-bottom:1px solid #{o.company_id and o.company_id.theme_color or '#000000'}; padding:0px"></td>
                </tr>
                <tr>
                    <td colspan="2" valign="top" align="left" style=" font-size:12px; padding:20px 0px 0 0;fnt-weight:bold;">
                <table class="table" width="100%" cellspacing="0" cellpadding="0" style="border:0.5px solid #ccc;  border-collapse: collapse; padding:15px; border-bottom:1px solid #ccc;">
                    <tr t-attf-style="background-color: #{o.company_id and o.company_id.theme_color or '#000000'}; color: #{o.company_id and o.company_id.theme_text_color or '#000000'};">
                        <td  align="center" width="8%" t-attf-style="padding:5px 10px; color: #{o.company_id and o.company_id.theme_text_color or '#000000'}; border:1px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; border-right:0px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; font-weight:bold;">Sr.</td>
                        <td align="left" width="52%" t-attf-style="padding:5px 10px; color: #{o.company_id and o.company_id.theme_text_color or '#000000'}; border:1px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; border-right:0px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; font-weight:bold;">Description</td>
                        <td align="center" width="14%" t-attf-style="padding:5px 10px; color: #{o.company_id and o.company_id.theme_text_color or '#000000'}; border:1px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; border-right:0px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; font-weight:bold;">Expected Date</td>
                        <td align="right" width="15%" t-attf-style="padding:5px 10px; color: #{o.company_id and o.company_id.theme_text_color or '#000000'}; border:1px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; border-right:0px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; font-weight:bold;">Qty</td>
                    </tr>
                   <div class="watermark pull-center" style="position:absolute;opacity:0.25;font-size:1em;width:90%;text-align:center;z-index:1000;height:100%;">
                        <img t-if="o.company_id" t-att-src="'data:image/png;base64,%s' %  o.company_id.watermark_logo"/>
                    </div>
                        <t t-foreach="o.order_line" t-as="l">
                            <t t-if="l_odd">
                                <tr t-att-style="'background-color: '+ o.company_id.even_party_color or o.company_id.even_party_color ">
                                    <td class="text-center" align="left" t-att-style="'padding:5px 10px; border:0.5px solid #ccc !important; border-right:0px solid #ccc !important; color: %s;' % (o.company_id.text_color)">
                                       <span t-out="l_index+1"/>
                                    </td>
                                    <td class="text-left" align="left" t-att-style="'padding:5px 10px; border:0.5px solid #ccc !important; border-right:0px solid #ccc !important; color: %s;' % (o.company_id.text_color)">
                                       <t t-if="not o.company_id.is_description"><span t-field="l.product_id and l.product_id.name"/></t>
                                       <t t-if="o.company_id.is_description"><span t-field="l.name"/></t>
                                    </td>
                                    <td class="text-center" align="center" t-att-style="'padding:5px 10px; border:0.5px solid #ccc !important; border-right:0px solid #ccc !important; color: %s;' % (o.company_id.text_color)">
                                        <span t-field="l.date_planned"/>
                                    </td>
                                    <td class="text-right" align="center" t-att-style="'padding:5px 10px; border:0.5px solid #ccc !important; border-right:0px solid #ccc !important; color: %s;' % (o.company_id.text_color)">
                                        <span t-field="l.product_qty"/>
                                        <span t-field="l.product_uom.name" groups="product.group_uom"/>
                                    </td>
                                </tr>
                            </t>
                            <t t-if="l_even">
                                <tr t-att-style="'background-color: '+ o.company_id.odd_party_color or o.company_id.odd_party_color ">
                                    <td class="text-center" align="left" t-att-style="'padding:5px 10px; border:0.5px solid #ccc !important; border-right:0px solid #ccc !important; color: %s;' % (o.company_id.text_color)">
                                       <span t-out="l_index+1"/>
                                    </td>
                                    <td class="text-left" align="left" t-att-style="'padding:5px 10px; border:0.5px solid #ccc !important; border-right:0px solid #ccc !important; color: %s;' % (o.company_id.text_color)">
                                       <t t-if="not o.company_id.is_description"><span t-field="l.product_id and l.product_id.name"/></t>
                                       <t t-if="o.company_id.is_description"><span t-field="l.name"/></t>
                                    </td>
                                    <td class="text-center" align="center" t-att-style="'padding:5px 10px; border:0.5px solid #ccc !important; border-right:0px solid #ccc !important; color: %s;' % (o.company_id.text_color)">
                                        <span t-field="l.date_planned"/>
                                    </td>
                                    <td class="text-right" align="center" t-att-style="'padding:5px 10px; border:0.5px solid #ccc !important; border-right:0px solid #ccc !important; color: %s;' % (o.company_id.text_color)">
                                        <span t-field="l.product_qty"/>
                                        <span t-field="l.product_uom.name" groups="product.group_uom"/>
                                    </td>
                                </tr>
                            </t>
                        </t>
                </table>
                </td>
                </tr>
                <tr>
                    <td colspan="3" t-attf-style="border-bottom:1px solid #{'#959595'}; padding:0px">
                    </td>
                </tr>
                <tr>
                    <td colspan="2" style="font-size:13px; color: #{o.company_id and o.company_id.text_color or '#000000'}; padding-top:100px; " class="pull-left">
                        <p t-field="o.notes" />
                    </td>
                </tr>
                <div class="oe_structure"/>
                </table>
                </center>
            </td>
        </tr>
    </tbody>
</table>
            </div>
        </t>
    </template>
    
    <template id="report_quotation_custom">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="verts_v15_print_template.report_quotation_main" t-lang="o.partner_id.lang"/>
            </t>
        </t>
    </template>
    
    <template id="purchase.report_purchasequotation">
    <t t-call="web.html_container">
        <t t-set="report_name" t-value="{'report_purchase_custom': 'verts_v15_print_template.report_quotation_main',
                                        'report_purchase_custom_creative': 'verts_v15_print_template.report_quotation_creative_main',
                                        'report_purchase_custom_elegant': 'verts_v15_print_template.report_quotation_elegant_main',
                                        'report_purchase_custom_professional': 'verts_v15_print_template.report_quotation_professional_main',
                                        'report_purchase_custom_exclusive': 'verts_v15_print_template.report_quotation_exclusive_main',
                                        'report_purchase_custom_advanced': 'verts_v15_print_template.report_quotation_advanced_main',}"/>
        <t t-foreach="docs" t-as="o">
            <t t-set="r_name" t-value="o.report_template_id and o.report_template_id.report_name or o.partner_id and o.partner_id.report_rfq_template_id and o.partner_id.report_rfq_template_id.report_name or o.company_id and o.company_id.report_rfq_template_id and o.company_id.report_rfq_template_id.report_name"/>
            <t t-set="real_name" t-value="r_name.split('.')"/>
            <t t-if="o.report_template_id or o.partner_id and o.partner_id.report_rfq_template_id or o.company_id and o.company_id.report_rfq_template_id">
                <!-- <t t-call="#{report_name.get(real_name[1], 'verts_v15_print_template.report_quotation_advanced_main')}" t-lang="o.partner_id.lang"/> -->
                <t t-if="r_name == 'verts_v15_print_template.report_purchase_custom'" t-call="verts_v15_print_template.report_quotation_main" t-lang="o.partner_id.lang"/>
                <t t-if="r_name == 'verts_v15_print_template.report_purchase_custom_creative'" t-call="verts_v15_print_template.report_quotation_creative_main" t-lang="o.partner_id.lang"/>
                <t t-if="r_name == 'verts_v15_print_template.report_purchase_custom_elegant'" t-call="verts_v15_print_template.report_quotation_elegant_main" t-lang="o.partner_id.lang"/>
                <t t-if="r_name == 'verts_v15_print_template.report_purchase_custom_professional'" t-call="verts_v15_print_template.report_quotation_professional_main" t-lang="o.partner_id.lang"/>
                <t t-if="r_name == 'verts_v15_print_template.report_purchase_custom_exclusive'" t-call="verts_v15_print_template.report_quotation_exclusive_main" t-lang="o.partner_id.lang"/>
                <t t-if="r_name == 'verts_v15_print_template.report_purchase_custom_advanced'" t-call="verts_v15_print_template.report_quotation_advanced_main" t-lang="o.partner_id.lang"/>
            </t>
        </t>
    </t>
    </template>
    
</data>
</odoo>