<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <!-- Form View -->
    <record id="view_awb_master_form" model="ir.ui.view">
        <field name="name">awb.master.form</field>
        <field name="model">awb.master</field>
        <field name="arch" type="xml">
            <form string="AWB Master">
                <header>
                    <button name="action_generate_awb_lines"
                            string="Generate AWB Numbers"
                            type="object"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <field name="airline_id" required="1"/>
                        <field name="date"/>
                        <field name="start_number" required="1"/>
                        <field name="end_number" required="1"/>
                        <field name="check_digit_start" required="1"/>
                        <field name="quantity" readonly="1"/>
                        <field name="remarks"/>
                    </group>
                    <notebook>
                        <page string="AWB Lines">
                            <field name="awb_line_ids" readonly="1">
                                <list editable="bottom">
                                    <field name="airline_id"/>
                                    <field name="awb_no"/>
                                    <field name="check_digit"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_awb_master_tree" model="ir.ui.view">
        <field name="name">awb.master.tree</field>
        <field name="model">awb.master</field>
        <field name="arch" type="xml">
            <list>
                <field name="airline_id"/>
                <field name="date"/>
                <field name="start_number"/>
                <field name="end_number"/>
                <field name="remarks"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_awb_master" model="ir.actions.act_window">
        <field name="name">AWB Master</field>
        <field name="res_model">awb.master</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first AWB Master
            </p>
        </field>
    </record>

    <record id="view_awb_master_line_tree" model="ir.ui.view">
        <field name="name">awb.master.line.tree</field>
        <field name="model">awb.master.line</field>
        <field name="arch" type="xml">
            <list create="false" edit="false" delete="false">
                 <field name="airline_id"/>
                 <field name="awb_no"/>
                 <field name="check_digit"/>
                 <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_awb_master_line_tree" model="ir.actions.act_window">
        <field name="name">AWB Numbers</field>
        <field name="res_model">awb.master.line</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
