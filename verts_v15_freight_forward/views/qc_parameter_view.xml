<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<!-- **********QC Parameter Tree view ********** -->
		<record id="qc_parameter_tree_view" model="ir.ui.view">
			<field name="name">QC Parameter</field>
			<field name="model">qc.parameter</field>
			<field name="arch" type="xml">
				<list>
					<field name="name" />
				</list>
			</field>
		</record>
		<!-- ********** QC Parameter form view ********** -->
		<record id="qc_parameter_form_view" model="ir.ui.view">
			<field name="name">QC Parameter</field>
			<field name="model">qc.parameter</field>
			<field name="arch" type="xml">
				<form string="QC Parameter">
					<sheet>
						<group>
							<group>
								<field name="name" required="1"/>
							</group>
						</group>
					</sheet>
				</form>
			</field>
		</record>
		<!-- ********** Action QC Parameter ********** -->
		<record id="action_qc_parameter" model="ir.actions.act_window">
			<field name="name">QC Parameter</field>
			<field name="type">ir.actions.act_window</field>
			<field name="res_model">qc.parameter</field>
			<field name="view_id" ref="verts_v15_freight_forward.qc_parameter_tree_view" />
			<field name="view_mode">list,form</field>
		</record>

	</data>
</odoo>



