<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<record id="ocean_vessel_tree_view" model="ir.ui.view">
			<field name="name">Ocean Vessels</field>
			<field name="model">ocean.vessel</field>
			<field name="arch" type="xml">
				<list>
					<field name="name" />
					<field name="shipping_line" />
					<field name="desc" />
				</list>
			</field>
		</record>

		<record id="ocean_vessel_form_view" model="ir.ui.view">
			<field name="name">Ocean Vessel</field>
			<field name="model">ocean.vessel</field>
			<field name="arch" type="xml">
				<form string="Ocean Vessel">
					<sheet>
						<group>
							<field name="name" required="1"/>
							<field name="shipping_line"  domain="[('is_shipping_line','=',True)]"/>
							<field name="desc" />
							<field name="imo_number"/>
							<field name="vessel_type"/>
							<field name="mmsi"/>
							<field name="call_sign"/>
							<field name="flag"/>
							<field name="gross_tonnage"/>
							<field name="summer_dwt"/>
							<field name="length_overall"/>
							<field name="year_built"/>
							<field name="home_port"/>
						</group>
					</sheet>
				</form>
			</field>
		</record>

		<record id="action_ocean_vessel" model="ir.actions.act_window">
			<field name="name">Ocean Vessel</field>
			<field name="type">ir.actions.act_window</field>
			<field name="res_model">ocean.vessel</field>
			<field name="view_id" ref="verts_v15_freight_forward.ocean_vessel_tree_view" />
			<field name="view_mode">list,form</field>
		</record>

	</data>
</odoo>


