<?xml version="1.0"?>
<odoo>
	<data>

		<record id="view_so_invoice_tree" model="ir.ui.view">
			<field name="name">so.invoice.value.tree</field>
			<field name="model">so.invoice.value</field>
			<field name="arch" type="xml">
				<list create="0" editable="bottom">
					<field name="sale_id" options='{"no_create": true, "no_open": true}' readonly="1"/>
					<field name="sale_state"/> 
					<field name="total_amount"/>
<!--					<field name="invoice_id" options='{"no_create": true, "no_open": true}'/>--><!--by kajal-->
<!--					<field name="invoice_amount"/> -->
<!--                    <field name="invoice_state"/> -->
					<field name="notify_id" options='{"no_create": true, "no_open": true}'/>
					<field name="consignee_id" options='{"no_create": true, "no_open": true}'/>
<!--					<field name="total_product" readonly="1"/> -->
					<field name="so_total_amount_usd" readonly="1" />
<!--                    <field name="amount_total_usd" readonly="1" />-->
<!--                    <field name="stuffing_point_id" options='{"no_create": true, "no_open": true}' readonly="1" />-->
<!--                    <field name="port_of_loading_id" options='{"no_create": true, "no_open": true}' readonly="1" />-->
                    <field name="production_date" /> 
                    <field name="stuffing_date"/> 
                    <field name="etd_date"/> 
                    <field name="eta_date"/> 
<!--                    <field name="total_paid_amount" readonly="1"/> -->
                    <field name="counter"/> 
                    <field name="line"/> 
                    <field name="remarks"/> 
<!--                    <field name="residual_usd" readonly="1"/> -->
				</list>
			</field>
		</record>

		<record id="so_invoice_val_suruchi_search" model="ir.ui.view">
            <field name="name">so.invoice.value.search</field>
            <field name="model">so.invoice.value</field>
            <field name="arch" type="xml">
				<search string="Invoices Analysis">
					<group expand="1" string="Group By">
						<filter string="Sale Status" name="sale_state" context="{'group_by':'sale_state'}"/>
					</group>
				</search>
            </field>
        </record>


		<record id="action_so_invoice_val_suruchi" model="ir.actions.act_window">
			<field name="name">So Invoice</field>
			<field name="type">ir.actions.act_window</field>
			<field name="res_model">so.invoice.value</field>
			<field name="view_mode">list</field>
			<field name="view_id" ref="view_so_invoice_tree" />
			<field name="search_view_id" ref="so_invoice_val_suruchi_search"/>
		</record>
		
	</data>
</odoo>
