                            <group>
                                <group>
                                    <button name="get_vendor_invoices" type="object" string="Load Invoices"
                                            class="btn-primary"
                                            invisible="state != 'posted'"/>
                                </group>
                                <group>
                                    <button name="adjust_manual" type="object" string="Adjust" class="btn-primary"
                                            invisible="state != 'posted'"/>
                                </group>
                            </group>
                            <field name="payment_invoice_ids">
                                <list editable="bottom" create="false" delete="false">
                                    <field name="is_select" nolabel="1"/>
                                    <field name="is_reconciled" invisible="1"/>
                                    <field name="invoice_id" readonly="1" force_save="1"/>
                                    <field name="origin"/>
                                    <field name="date_invoice"/>
                                    <field name="date_due"/>
                                    <field name="amount_total"/>
                                    <field name="residual"/>
                                    <field name="reconcile_amount"/>
                                    <field name="currency_id" invisible="1"/>
                                    <field name="payment_state" invisible="1"/>
                                </list>
                            </field>

                        </page>
                        <page string="Adjusted Invoices">
                            <field name="adjusted_invoice_ids" readonly="1">
                                <list>
                                    <field name="invoice_id"/>
                                    <field name="origin"/>
                                    <field name="date_invoice"/>
                                    <field name="date_due"/>
                                    <field name="reconcile_amount" sum="reconcile_amount"/>
                                    <field name="currency_id" invisible="1"/>
                                </list>
                            </field>
