<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_picking_export_inherit" model="ir.ui.view">
            <field name="name">stock.picking.form</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form" />
			<field name="arch" type="xml">
				 <xpath expr="//form/sheet/group/group/field[@name='backorder_id']" position="after">
                     <field name="is_export" invisible="1"/>
        		</xpath>
                 <xpath expr="//form/sheet/notebook/page/field[@name='move_ids_without_package']/list/field[@name='product_id']" position="after">
                     <field name="packing_type"/>
                     <field name="bag_box_qty"/>
        		</xpath>
        		<notebook position="inside">
                     <page name="export_specification" string="Export Product Specification">
                            <field name="qc_pro_specification_line" >
                                <list editable="bottom">
                                    <field name="qc_parameter_id" required="1"/>
                                    <field name="value"/>
                                </list>
                            </field>
                        </page>
        		</notebook>
            </field>
        </record>

    </data>
</odoo>


