<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<record id="bill_lading_type_tree_view" model="ir.ui.view">
			<field name="name">Bill of Lading Types</field>
			<field name="model">bill.lading.type</field>
			<field name="arch" type="xml">
				<list>
					<field name="name" />
					<field name="desc" />
				</list>
			</field>
		</record>

		<record id="bill_lading_type_form_view" model="ir.ui.view">
			<field name="name">Bill of Lading Types</field>
			<field name="model">bill.lading.type</field>
			<field name="arch" type="xml">
				<form string="Bill of Lading Type">
					<sheet>
						<group>
							<field name="name" required="1"/>
							<field name="desc" />
						</group>
					</sheet>
				</form>
			</field>
		</record>

		<record id="action_bill_lading_type" model="ir.actions.act_window">
			<field name="name">Bill of Lading Types</field>
			<field name="type">ir.actions.act_window</field>
			<field name="res_model">bill.lading.type</field>
			<field name="view_id" ref="verts_v15_freight_forward.bill_lading_type_tree_view" />
			<field name="view_mode">list,form</field>
		</record>

	</data>
</odoo>