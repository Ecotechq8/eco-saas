<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>

		<record id="spice_board_rate_master_tree_view" model="ir.ui.view">
			<field name="name">Spice Board Rate Master</field>
			<field name="model">spice.board.rate.master</field>
			<field name="arch" type="xml">
				<list>
					<field name="country_id" />
					<field name="qc_id" />
					<!--<field name="rate_small_five" />-->
					<!--<field name="rate_greater_five" />-->
					<field name="product_id" />
					<!--<field name="categ_id" />-->
				</list>
			</field>
		</record>

		<record id="spice_board_rate_master_form_view" model="ir.ui.view">
			<field name="name">Spice Board Rate Master</field>
			<field name="model">spice.board.rate.master</field>
			<field name="arch" type="xml">
				<form string="Spice Board Rate Master">
					<sheet>
						<group>
							<field name="country_id" />
							<field name="qc_id" />
							<!--<field name="rate_small_five" />-->
							<!--<field name="rate_greater_five" />-->
							<field name="product_id" options='{"no_create": true}' domain="[('is_export_expense','=',True)]"/>
							<!--<field name="categ_id" readonly="1" force_save="1"/>-->
						</group>
						<field name="spice_board_line" >
							<list editable="bottom">
								<field name="product_id" options='{"no_create": true}'/>
								<!--<field name="categ_id" />-->
								<field name="from_qty"/>
								<field name="to_qty"/>
								<field name="price"/>
							</list>
						</field>
					</sheet>
				</form>
			</field>
		</record>

		<record id="action_spice_board_rate_master" model="ir.actions.act_window">
			<field name="name">Spice Board Rate Master</field>
			<field name="type">ir.actions.act_window</field>
			<field name="res_model">spice.board.rate.master</field>
			<field name="view_id" ref="verts_v15_freight_forward.spice_board_rate_master_tree_view" />
			<field name="view_mode">list,form</field>
		</record>

	</data>
</odoo>



