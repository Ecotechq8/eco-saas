<odoo>
    <record id="view_cv_csr_report_form" model="ir.ui.view">
        <field name="name">cv.csr.report.form</field>
        <field name="model">cv.csr.report</field>
        <field name="arch" type="xml">
            <form string="CSR Report">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,posted"/>
                    <button name="action_post" type="object" string="Confirm" class="btn-primary"/>
                      <button name="%(action_cv_csr_report_qweb)d"
                        string="Print CSR Report"
                        type="action"
                        class="btn btn-primary"
                        invisible="state != 'posted'"/>
                     <button name="action_generate_excel"
                        string="Print Excel"
                        type="object"
                        class="btn-primary"/>
                <button string="Cancel" special="cancel" class="btn-secondary"/>
                </header>

                <sheet>
                    <!-- ✅ Add the name field right after the header -->
                    <field name="sequence" readonly="1" widget="char" class="mb-3"/>

                    <group>
                        <group>
                            <field name="type"/>
                            <field name="partner_id"/>
                            <field name="commission_percentage" invisible="type == 'customer'"/>
                            <field name="remarks"/>

                        </group>
                        <group>
                            <field name="company_id" readonly="1"/>
                            <field name="date"/>
                            <label for="date_from" string="Date From"/>
                            <div>
                                <!-- Edit mode -->
                                <div name="route_only" class="o_row oe_edit_only">
                                    <field name="date_from" class="oe_inline" required="1"/>
                                    <i class="fa fa-long-arrow-right mx-2" aria-label="Arrow icon" title="Arrow"/>
                                    <field name="date_to" class="oe_inline" required="1"/>
                                </div>

                                <!-- Read-only mode -->
                                <div name="route_read_only" class="o_row oe_read_only">
                                    <span t-if="record.date_from.raw_value">
                                        <field name="date_from" class="oe_inline"/>
                                    </span>
                                    <i class="fa fa-long-arrow-right mx-2" aria-label="Arrow icon" title="Arrow"/>
                                    <span t-if="record.date_to.raw_value">
                                        <field name="date_to" class="oe_inline"/>
                                    </span>
                                </div>
                            </div>
                        </group>
                    </group>

                    <button name="fetch_cv_csv_lines_commission"
                            string="Fetch Commission"
                            type="object"
                            class="oe_highlight"
                            help="Click on this button will fetch commission lines"
                    />
                    <field name="purchase_order_line_ids" invisible="1"/>

                    <notebook>
                        <page string="Report Lines">
                            <field name="cv_line_ids">
                                <list editable="bottom">
                                    <field name="type" invisible="1"/>
                                    <field name="date"/>
                                    <field name="agent_id"/>
                                    <field name="mawb"/>
                                    <field name="destination_code"/>
                                    <field name="gross_weight"/>
                                    <field name="chargeable_weight"/>
                                    <field name="rate"/>
                                    <field name="air_freight"/>
                                    <field name="other_charges"/>
                                    <field name="total_amount"/>
                                    <field name="amount"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_cv_csr_report_tree" model="ir.ui.view">
        <field name="name">cv.csr.report.tree</field>
        <field name="model">cv.csr.report</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="type"/>
                <field name="partner_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
            </list>
        </field>
    </record>


    <record id="action_cv_csr_report" model="ir.actions.act_window">
        <field name="name">CSR Report</field>
        <field name="res_model">cv.csr.report</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
