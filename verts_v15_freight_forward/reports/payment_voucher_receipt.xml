                                </td>
                                <td valign="top" align="left"
                                    style="padding:2px; width:40%;">
                                    <table width="100%" cellspacing="0" cellpadding="0"
                                           t-attf-style="padding:0px 10px; color: #{'#000000'}; border:1px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important;">
                                        <tr t-attf-style="color: #{o.company_id and o.company_id.theme_text_color or '#000000'}; background-color: #{o.company_id and o.company_id.theme_color or '#000000'};">
                                            <td align="center"
                                                style="padding: 5px; font-weight:bold; font-size:26px;">
                                                <span>PAYMENT VOUCHER</span>
                                            </td>
                                        </tr>

                                        <tr t-attf-style="color: #{o.company_id and o.company_id.text_color or '#000000'};">
                                            <td width="50%" style="padding:0px 0px 0px 5px;">
                                                <t>
                                                    <b>Voucher No:</b>
                                                </t>
                                            </td>
                                            <td width="50%" style="text-align:right; padding:0px 15px 0px 0px;"
                                                t-attf-style="padding:0px 10px; color: #{'#000000'}; border-right:1px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important;">
                                                <span t-field="o.name"/>
                                            </td>
                                        </tr>

                                        <tr t-attf-style="color: #{o.company_id and o.company_id.text_color or '#000000'};">
                                            <td width="50%" style="padding:0px 0px 0px 5px;">
                                                <t t-if="o.payment_type == 'inbound'">
                                                    <b>Receipt Date:</b>
                                                </t>
                                                <t t-if="o.payment_type == 'outbound'">
                                                    <b>Voucher Date:</b>
                                                </t>
                                            </td>
                                            <td width="50%" style="text-align:right; padding:0px 15px 0px 0px;"
                                                t-attf-style="padding:0px 10px; color: #{'#000000'}; border-right:1px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important;">
                                                <span t-field="o.date"/>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>

                        <tbody>
                            <br/>
                            <table border="0" cellspacing="0" cellpadding="0" width="100%"
                                   t-attf-style="font-size:12px; margin:0; font-family: Arial,Helvetica, sans-serif; background:#fff; line-height:20px; border:1px solid #{o.company_id and o.company_id.theme_color or '#000000'};">
                                <tr t-attf-style="padding:5px 10px; border:1px solid #{o.company_id and o.company_id.theme_color or '#000000'}; font-weight:bold; background-color: #{o.company_id and o.company_id.theme_color or '#000000'}; color: #{o.company_id and o.company_id.theme_text_color or '#000000'};">
                                    <td align="center" width="100%"
                                        t-attf-style="padding:5px 10px; color: #{o.company_id and o.company_id.theme_text_color or '#000000'}; border:1px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; border-right:0px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; font-weight:bold;">
                                        <b>
                                            <span>Party Details:</span>
                                        </b>
                                        <br/>
                                    </td>
                                </tr>

                                <tr>
                                    <th align="center" width="10%"
                                        t-attf-style="padding:0px 10px; color: #{'#000000'}; border:1px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; border-right:0px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important;">
                                        Name:
                                        <br/>
                                        Address:
                                        <br/>
                                        <br/>
                                    </th>
                                    <td align="left" width="90%"
                                        t-attf-style="padding:0px 10px; color: #{'#000000'}; border:1px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; border-right:0px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important;">
                                        <span t-field="o.partner_id.name"/>
                                        <br/>
                                        <span t-if="o.partner_id.street">
                                            <span t-field="o.partner_id.street"/>
                                            <br/>
                                        </span>
                                        <span t-if="o.partner_id.street2">
                                            <span t-field="o.partner_id.street2"/>
                                            <br/>
                                        </span>
                                        <span t-if="o.partner_id.city">
                                            <span t-field="o.partner_id.city"/>,
                                        </span>
                                        <span t-if="o.partner_id.state_id.name">
                                            <span t-field="o.partner_id.state_id.name"/>,
                                        </span>
                                        <span t-if="o.partner_id.zip">
                                            <span t-field="o.partner_id.zip"/>,
                                        </span>
                                        <br/>
                                        <span t-if="o.partner_id.country_id.name">
                                            <span t-field="o.partner_id.country_id.name"/>
                                            <br/>
                                        </span>
                                    </td>
                                </tr>
                            </table>
                        </tbody>
                        <tbody>
                            <p/>
                            <table border="0" cellspacing="0" cellpadding="0" width="100%"
                                   t-attf-style="font-size:12px; margin:0; font-family: Arial,Helvetica, sans-serif; background:#fff; line-height:20px; border:1px solid #{o.company_id and o.company_id.theme_color or '#000000'};">
                                <tr t-attf-style="padding:5px 10px; border:1px solid #{o.company_id and o.company_id.theme_color or '#000000'}; font-weight:bold; background-color: #{o.company_id and o.company_id.theme_color or '#000000'}; color: #{o.company_id and o.company_id.theme_text_color or '#000000'};">
                                    <td
                                            t-attf-style="padding:5px 10px; color: #{o.company_id and o.company_id.theme_text_color or '#000000'}; border:1px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; border-right:0px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; font-weight:bold;"
                                            style="width:80%;">
                                        <center>
                                            <b>Details of Payment</b>
                                        </center>
                                    </td>
                                    <td
                                            t-attf-style="padding:5px 10px; color: #{o.company_id and o.company_id.theme_text_color or '#000000'}; border:1px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; border-right:1px solid #{o.company_id and o.company_id.theme_color or '#000000'} !important; font-weight:bold;"
                                            style="width:20%;">
                                        <center>
                                            <b>Paid Amount</b>
                                        </center>
                                    </td>
                                </tr>
                                <tr style="width:100%;border: 1px solid black;font-size:10px;">
                                    <td style="width:80%;border: 1px solid black">
                                        <center>
                                            <span t-out="o.ref"/>
                                        </center>
                                    </td>
                                    <td style="border: 1px solid black">
                                        <center>
                                            <span t-out="o.currency_id.symbol"/>
                                            <span t-out="'{0:,.3f}'.format(o.amount)"/>
                                        </center>
                                    </td>
                                </tr>
                            </table>
                            <p/>
                            <!-- Payment Table -->
                            <table border="0" cellspacing="0" cellpadding="0" width="100%"
                                   t-attf-style="font-size:12px; margin:0; font-family: Arial, Helvetica, sans-serif; background:#fff; line-height:20px;">
                                <tr>
                                    <!-- Left Side: Payment Details -->
                                    <td style="width:65%; border: 1px solid #{o.company_id and o.company_id.theme_color or '#000000'}; padding:10px;"
                                        rowspan="4" valign="top">

                                        <b>Amount In Words:</b>
                                        <span t-out="o.currency_id.symbol"/>
                                        <span t-out="o.currency_id.amount_to_text(o.amount)"/>
                                        <br/>

                                        <b>Paid by :</b>
                                        <br/>
                                        <br/>

                                        <b>Payment Mode :</b>

                                        <t t-if="o.is_cheque">
                                            <!-- Cash -->
                                            Cash &#x2610;

                                            <!-- Cheque -->
                                            <span style="padding: 0 10px;">
                                                Cheque &#x2611;
                                            </span>

                                            <!-- Bank -->
                                            <span style="padding: 0 10px;">
                                                Bank &#x2610;
                                            </span>
                                        </t>

                                        <t t-elif="o.journal_id.type == 'bank'">
                                            <!-- Cash -->
                                            Cash &#x2610;

                                            <!-- Cheque -->
                                            <span style="padding: 0 10px;">
                                                Cheque &#x2610;
                                            </span>

                                            <!-- Bank -->
                                            <span style="padding: 0 10px;">
                                                Bank &#x2611;
                                            </span>
                                        </t>

                                        <t t-else="">
                                            <!-- Cash -->
                                            Cash &#x2611;

                                            <!-- Cheque -->
                                            <span style="padding: 0 10px;">
                                                Cheque &#x2610;
                                            </span>

                                            <!-- Bank -->
                                            <span style="padding: 0 10px;">
                                                Bank &#x2610;
                                            </span>
                                        </t>

                                        <br/>
                                        <br/>

                                        <b>Cheque No.:</b>
                                        <t t-if="o.is_cheque and o.cheque_number">
                                            <t t-out="o.cheque_number"/>
                                        </t>
                                        <t t-if="not (o.is_cheque and o.cheque_number)">______________</t>
                                        ,
                                        <b>Drawn on :</b>
                                        <t t-if="o.is_cheque and o.drawn_on">
                                            <t t-out="o.drawn_on"/>
                                        </t>
                                        <t t-if="not (o.is_cheque and o.drawn_on)">___________________________</t>

                                        <br/>
                                        <br/>

                                        <b>Cheque Date :</b>
                                        <t t-if="o.is_cheque and o.cheque_date">
                                            <t t-out="o.cheque_date.strftime('%d/%m/%Y')"/>
                                        </t>
                                        <t t-if="not (o.is_cheque and o.cheque_date)">______________</t>
                                    </td>


                                    <!-- TOTAL PAID AMOUNT Header -->
                                    <td align="right"
                                        t-attf-style="padding:5px 10px; font-weight:bold; border: 1px solid #{o.company_id and o.company_id.theme_color or '#000000'}; background-color: #{o.company_id and o.company_id.theme_color or '#000000'}; color: #{o.company_id and o.company_id.theme_text_color or '#FFFFFF'};">
                                        TOTAL PAID AMOUNT
                                    </td>
                                </tr>

                                <!-- TOTAL Amount Value -->
                                <tr>
                                    <td align="right"
                                        t-attf-style="padding:5px 10px; border: 1px solid #{o.company_id and o.company_id.theme_color or '#000000'}; font-weight:bold;">
                                        <span t-out="o.currency_id.symbol"/>
                                        <span t-out="'{0:,.3f}'.format(o.amount)"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td align="right"
                                        t-attf-style="padding:5px 10px; border: 1px solid #{o.company_id and o.company_id.theme_color or '#000000'}; font-weight:bold;">
                                        <t t-out="abs(o.amount_company_currency_signed)"
                                           t-options='{"widget": "monetary", "display_currency": o.company_currency_id}'/>
                                    </td>
                                </tr>

                                <!-- Empty Space -->
                                <tr style="width:35%;border: 0px solid #fff;font-size:14px;">
                                    <td align="right"
                                        style="padding:7px; border-left: 1px solid #fff; border-right: 1px solid #fff;">
                                        <b>For
                                            <span t-field="o.company_id.name"/>
                                        </b>
                                        <br/>
                                    </td>
                                </tr>

                            </table>
                            <br/>
                            <br/>
                            <br/>
                            <table style="width: 100%; border: 1px solid #000; font-size: 11px; border-collapse: collapse;">

                                <tr>
                                    <td style="padding: 6px; text-align: center; font-weight: bold;">Prepared By</td>
                                    <td style="padding: 6px; text-align: center; font-weight: bold;">Checked By</td>
                                    <td style="padding: 6px; text-align: center; font-weight: bold;">Authorised By</td>
                                    <td style="padding: 6px; text-align: center; font-weight: bold;">Approved By</td>
                                    <td style="padding: 6px; text-align: center; font-weight: bold;">Received By</td>
                                </tr>
                                <tr>
                                    <td style="height: 40px; text-align: center;">
                                        <span t-out="o.create_uid.name"/>
                                    </td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                </tr>
                            </table>

                            <t t-if="o.move_id.line_ids">
                                <h4 style="text-align: center;">Journal Details</h4>
                                <table border="0" cellspacing="0" cellpadding="0" width="100%"
                                       t-attf-style="font-size:12px; margin:0; font-family: Arial,Helvetica, sans-serif; background:#fff; line-height:20px; border:1px solid #{o.company_id and o.company_id.theme_color or '#000000'};">
                                    <thead>
                                        <tr t-attf-style="padding:5px 10px; border:1px solid #{o.company_id and o.company_id.theme_color or '#000000'}; font-weight:bold; background-color: #{o.company_id and o.company_id.theme_color or '#000000'}; color: #{o.company_id and o.company_id.theme_text_color or '#000000'};">
                                            <th width="20%" style="padding:4px;">Account</th>
                                            <th width="20%" style="padding:4px;">Partner</th>
                                            <th width="26%" style="padding:4px;">Label</th>
                                            <th width="10%" style="padding:4px;">Currency</th>
                                            <th width="12%" style="padding:4px;">Debit</th>
                                            <th width="12%" style="padding:4px;">Credit</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="o.move_id.line_ids" t-as="line">
                                            <tr>
                                                <td style="padding:4px;">
                                                    <t t-out="line.account_id.display_name"/>
                                                </td>
                                                <td style="padding:4px;">
                                                    <t t-out="line.partner_id.name or ''"/>
                                                </td>
                                                <td style="padding:4px;">
                                                    <t t-out="line.name or ''"/>
                                                </td>
                                                <td style="padding:4px;">
                                                    <t t-out="o.company_currency_id.name or ''"/>
                                                </td>
                                                <td style="padding:4px;">
                                                    <t t-out="'%.3f' % line.debit"/>
                                                </td>
                                                <td style="padding:4px;">
                                                    <t t-out="'%.3f' % line.credit"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </t>

                            <!-- Add space to push footer to bottom -->
                            <div style="height: 250px;"></div>

                            <!-- Footer Row at Bottom -->
                            <table width="100%" style="margin-top: 30px; font-size: 12px;">
                                <tr>
                                    <td style="text-align: left;">
                                        <strong>Prepared On :</strong>
                                        <t t-out="o.prepared_on and o.prepared_on.strftime('%d/%m/%Y %H:%M:%S') or ''"/>
                                        <br/>
                                        This is a system generated payment receipt and does not require any signature
                                    </td>
                                    <td style="text-align: right;">
                                        <strong>Issued by :</strong>
                                        <t t-out="o.issued_by.name or ''"/>
                                    </td>
                                </tr>
                            </table>

                            <br/>
                            <br/>
                            <br/>
                        </tbody>
                    </div>
                    <div style="page-break-before: always;"></div>

                </t>
            </t>
        </template>


    </data>
    <record id="paperformat_payment_voucher_report"
            model="report.paperformat">
        <field name="name">Payment and Receipt Format</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">7</field>
        <field name="margin_right">7</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">55</field>
        <field name="dpi">90</field>
    </record>

    <report
            id="account.action_report_payment_voucher"
            model="account.payment"
            string="Payment Receipt"
            report_type="qweb-pdf"
            name="account.report_payment_voucher"
            file="account.report_payment_voucher"
            menu="False"
    />

    <report id="payment_voucher_report_id"
            string="Payment Voucher"
            model="account.payment"
            report_type="qweb-pdf"
            file="verts_v15_freight_forward.payment_voucher_report_temp"
            name="verts_v15_freight_forward.payment_voucher_report_temp"
            paperformat="verts_v15_freight_forward.paperformat_payment_voucher_report"
            menu="False"
    />
</odoo>