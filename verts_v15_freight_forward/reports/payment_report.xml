<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <template id="report_payment_cheque_print_id">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <style>
                        .cheque-container {
                        position: relative;
                        width: 100%;
                        height: 100%;
                        background-image: url('/your_module/static/src/img/output-1.png');
                        background-size: cover;
                        font-size: 15px;
                        }

                        .cheque-field {
                        position: absolute;
                        font-family: Arial, sans-serif;
                        }

                        .cheque-date {
                        font-weight: bold;
                        top: 21mm;
                        left: 190mm;
                        font-size: 15px;
                        }

                        .cheque-name {
                        font-weight: bold;
                        top: 38mm;
                        left: 12mm;
                        font-size: 15px;
                        width: 260mm;
                        }

                        .cheque-amount-num {
                        font-weight: bold;
                        top: 55mm;
                        left: 185mm;
                        white-space: nowrap;
                        font-size: 15px !important;
                        }

                        .cheque-amount-text {
                        font-weight: bold;
                        top: 49mm;
                        left: 10mm;
                        width: 160mm;
                        font-size: 15px;
                        }
                    </style>

                    <div class="cheque-container">
                        <div class="cheque-field cheque-date">
                            <t t-out="doc.date.strftime('%d-%b-%Y')"/>
                        </div>
                        <div class="cheque-field cheque-name">
                            <t t-out="doc.partner_id.name"/>
                        </div>
                        <div class="cheque-field cheque-amount-num">
                            <t t-out="'%.3f' % doc.amount"/>
                        </div>
                        <div class="cheque-field cheque-amount-text">
                            <t t-out="doc._get_amount_in_words()"/>
                        </div>
                    </div>
                </t>
            </t>
        </template>

    </data>

    <record id="paperformat_payment_cheque_print_id"
            model="report.paperformat">
        <field name="name">Payment - Cheque Print Format</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">7</field>
        <field name="margin_right">7</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">55</field>
        <field name="dpi">90</field>
    </record>

    <report id="report_check_print_id"
            string="Cheque Print"
            model="account.payment"
            report_type="qweb-pdf"
            file="verts_v15_freight_forward.report_payment_cheque_print_id"
            name="verts_v15_freight_forward.report_payment_cheque_print_id"
            paperformat="verts_v15_freight_forward.paperformat_payment_cheque_print_id"
    />

</odoo>