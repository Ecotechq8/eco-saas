<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <template id ="price_check_list_report">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <style  type="text/css">
                        .tbl_bdr
                        {
                         margin:0;
                         padding:0;
                        }
                        .tbl_bdr tr th
                        {
                         margin:0;
                         padding:0;
                         border:1px solid #cccccc;
                        }
                        .tbl_bdr tr td
                        {
                         margin:0;
                         padding:0;
<!--                         text-align:left;-->
                         border:1px solid #cccccc;
                        }
                    </style>
                    <table style="width:100%; border: 1px solid black;">
                        <tr>
                            <td>
                                <table style="width:100%">
                                    <tr>
                                        <td>
                                            <img t-if="o.company_id.logo"
                                        t-attf-src="data:image/*;base64,{{o.company_id.logo}}"
                                        style="height: 80px;padding-bottom: 10px;" align="left" />
                                        </td>
                                        <td style="font-size:12px;">
                                            <center>
                                                <u><h3><b>PRICE CHECK LIST</b></h3></u>
                                            </center>
                                        </td>
                                        <td style="font-size:10px;">
                                            <p align="right">
                                                Date :<span t-field="doc.date_order" t-options='{"format": "dd/MM/yyyy"}' />
                                            </p>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
<!--                        <tr>-->
<!--                            <td style="font-size:10px;">-->
<!--                                <p align="right">-->
