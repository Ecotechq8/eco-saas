                        <tr>
                            <td>
                                <table width="100%" class="tbl_bdr" align="center" >
                                    <tr>
                                       <td style="font-size:10px;" width="20%"> Party Name </td>
                                       <td style="font-size:10px;" width="30%"> <span t-field="o.partner_id" /></td>
                                       <td style="font-size:10px;" width="20%"> Checklist No </td>
                                       <td style="font-size:10px;" width="30%"> <span t-field="o.name" /></td>
                                    </tr>
                                    <tr>
                                        <td style="font-size:10px;" width="20%"> Shipping line </td>
                                        <td style="font-size:10px;" width="30%"><span t-field="o.freight_forwarder_id" /> </td>
                                        <td style="font-size:10px;" width="20%"> Destination </td>
                                        <td style="font-size:10px;" width="30%">  <span t-field="o.port_of_discharge_id" /><span t-out="o.cal_port_of_discharge_id()" /></td>
                                    </tr>
                                    <tr>
                                        <td style="font-size:10px;" width="20%"> Transit Time </td>
                                        <td style="font-size:10px;" width="30%"><span t-out="o.cal_transit_time()" /></td>
                                        <td style="font-size:10px;" width="20%"> Dollar Rate </td>
                                        <td style="font-size:10px;" width="30%"> <span t-out="o.cal_cur_rate()" /> </td>
                                    </tr>
                                    <tr>
                                        <td style="font-size:10px;" width="20%"> Stuffing Location </td>
                                        <td style="font-size:10px;" width="30%"> <span t-field="o.stuffing_point_id" /> </td>
                                        <td style="font-size:10px;" width="20%"> Lot No </td>
                                        <td style="font-size:10px;" width="30%">  </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
<!--                        <tr>-->
<!--                            <td>-->
<!--                                <br/>-->
<!--                            </td>-->
<!--                        </tr>-->

                        <tr>
                            <td>
                                <table width="100%" class="tbl_bdr"  align="center" >
                                  <tr>
                                  <th width="50%" style="font-size:10px;text-align:center"> Product </th>
                                  <th width="40%" style="font-size:10px;text-align:center">Product Quantity</th>
                                  <th width="10%" style="font-size:10px;text-align:center"> Rate </th>
                                  </tr>

                                   <t t-foreach="o.order_line" t-as="line">
                                      <tr>
                                            <td style="font-size:10px;" align="center">
                                                <span t-field="line.product_id"/>
                                            </td>
                                            <td style="font-size:10px;" align="center">
                                                <span t-out="'%.3f'%(line.product_uom_qty)"/>
                                            </td>
                                            <td style="font-size:10px;" align="center">
                                                <span t-out="'%.3f'%(line.price_unit)"/>
                                            </td>
                                      </tr>
                                    </t>
                                 </table>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <table width="100%" class="tbl_bdr" align="center" >
                                    <tr>
                                        <th width="50%" style="font-size:10px;text-align:center"> Container Type </th>
                                        <th width="40%" style="font-size:10px;text-align:center">Capacity</th>
                                        <th width="10%" style="font-size:10px;text-align:center"> Quantity </th>
                                    </tr>

                                    <t t-foreach="o.container_detail_line" t-as="line">
                                        <tr>
                                            <td style="font-size:10px;" align="center">
                                                <span t-field="line.container_type_id"/>
                                            </td>
                                            <td style="font-size:10px;" align="center">
                                                <span t-out="'%.3f'%(line.capacity_in_mt)"/>
                                            </td>
                                            <td style="font-size:10px;" align="center">
                                                <span t-out="'%.3f'%(line.container_qty)"/>
                                            </td>
                                      </tr>
                                    </t>
                                </table>
                            </td>
                        </tr>
                    </table>


                    <table style="width:100%; border: 1px solid black;" align="center">
<!--                        <tr>-->
<!--                            <td>-->
<!--                                <table width="100%" class="tbl_bdr" align="center" >-->
                                    <tr>
                                        <th width="20%" style="font-size:10px;border-right: 1px solid black;border-bottom: 1px solid black;text-align:center">Expense Related To</th>
        <!--                                <th width="16%" style="text-align:left">Product Class</th>-->
                                        <th width="20%" style="font-size:10px;border-right: 1px solid black;border-bottom: 1px solid black;text-align:center">Expense Name</th>
                                        <th width="15%" style="font-size:10px;border-right: 1px solid black;border-bottom: 1px solid black;text-align:center">USD</th>
                                        <th width="15%" style="font-size:10px;border-right: 1px solid black;border-bottom: 1px solid black;text-align:center">Rate</th>
                                        <th width="15%" style="font-size:10px;border-right: 1px solid black;border-bottom: 1px solid black;text-align:center">Amount</th>
                                        <th width="15%" style="font-size:10px;border-bottom: 1px solid black;text-align:center">Remarks</th>
                                    </tr>
                                    <t t-foreach="o.sale_expense_line" t-as="line">
                                        <tr>
                                            <td align="left" style="font-size:10px;border-right: 1px solid black;border-bottom: 1px solid black;">
                                                <span t-field="line.exp_related_to"/>
                                            </td>
        <!--                                    <td  style="border-collapse: collapse; border:solid 1p" align="left" width="16%">-->
        <!--										<span t-field="line.product_class"/>-->
        <!--									</td>-->
                                            <td align="left" style="font-size:10px;border-right: 1px solid black;border-bottom: 1px solid black;">
                                                <span t-field="line.expense_id"/>
                                            </td>
                                            <td align="right" style="font-size:10px;border-right: 1px solid black;border-bottom: 1px solid black;">
                                                <span t-out="'%.3f'%(line.usd_value)"/>
                                            </td>
                                            <td align="right"  style="font-size:10px;border-right: 1px solid black;border-bottom: 1px solid black;">
                                                <span t-out="'%.3f'%(line.rate)"/>
                                            </td>
                                            <td align="right"  style="font-size:10px;border-right: 1px solid black;border-bottom: 1px solid black;">
                                                <span t-out="'%.3f'%(line.exp_amt)"/>
                                            </td>
                                            <td align="right" style="font-size:10px;border-bottom: 1px solid black;">
                                                <span t-field="line.remark"/>
                                            </td>
                                      </tr>
                                    </t>
                                    <tr>
                                        <td align="right"  style="font-size:10px;"><b>Total Expense</b></td>
                                        <td align="right">
                                           <b><span t-out="'%.3f'%(o.total_expense)"/></b>
                                        </td>
                                        <td></td>
                                    </tr>
<!--                                 </table>-->
<!--                            </td>-->
<!--                        </tr>-->
                    </table>

                    <table width="100%" ><tr>
                            <td style="font-size:10px;"><text ><u>Cost Summary</u></text></td>
                        </tr>
<!--                         <br></br>-->
                    </table>

                    <table style="font-size:10px;border: 1px solid #000000;" width="100%" align="center">
                          <tr>
<!--                          <th width="19%">Product Name </th>-->
                              <th style="font-size:10px;border-right: 1px solid #000000;border-bottom: 1px solid #000000;" width="50%">Rate Per KG INR</th>
