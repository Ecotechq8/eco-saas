    <record id="journal_paperformat_report_payment_and_receipt"
            model="report.paperformat">
        <field name="name">Payment and Receipt Format</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">7</field>
        <field name="margin_right">7</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">55</field>
        <field name="dpi">90</field>
    </record>

    <report id="journal_report_payment_and_receipt_id"
            string="Journal Voucher"
            model="account.move"
            report_type="qweb-pdf"
            file="verts_v15_freight_forward.journal_report_payment_and_receipt"
            name="verts_v15_freight_forward.journal_report_payment_and_receipt"
            paperformat="verts_v15_freight_forward.journal_paperformat_report_payment_and_receipt"
    />

