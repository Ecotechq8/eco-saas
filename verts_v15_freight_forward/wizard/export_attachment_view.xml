<odoo>
    <data>
        <record id="export_attachment_form_view" model="ir.ui.view">
            <field name="name">export.schedule.attachment.form</field>
            <field name="model">export.schedule.attachment</field>
            <field name="arch" type="xml">
                <form string="Export Attachment">
                <group>
                	<group >
                        <field name="export_attachment_lines" readonly="0">
						<list editable="bottom" delete="0">
			                   <field name="remark" invisible="0"/>
			                    <field name="attachment_value" invisible="0" force_save="1"/>
			               </list>
					</field>
                    </group>
                    </group>
                     <footer>
                         <button name="attach_button" string="Print" type="object" class="oe_highlight" />
                         <button string="Cancel" class="oe_link" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>
        <record id="action_export_attachment" model="ir.actions.act_window">
            <field name="name">Export Attachment</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">export.schedule.attachment</field>
            <field name="view_type">form</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>