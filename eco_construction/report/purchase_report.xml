<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_purchaseorder_signature_inherit"
                  inherit_id="purchase.report_purchaseorder_document">

            <xpath expr="//div[@class='page']" position="inside">

                <!-- ================= SIGNATURE SECTION ================= -->
                <div style="margin-top:60px;">

                    <table style="width:100%; text-align:center; border-collapse:collapse;">

                        <tr>

                            <!-- PURCHASE ADMIN -->
                            <td>
                                <strong>Purchase Admin</strong>
                                <div style="margin-top:30px;">
                                    <t t-if="o.purchase_approved_by and o.state in ['purchase_admin','planning','operation','general']">
                                        <span t-esc="o.purchase_approved_by.name"/>
                                    </t>
                                    <t t-else="">
                                        ____________________
                                    </t>
                                </div>
                            </td>

                            <!-- PROJECT MANAGER (ALWAYS) -->
                            <td>
                                <strong>Project Manager</strong>
                                <div style="margin-top:30px;">
                                    <t t-if="o.project_id and o.project_id.user_id">
                                        <span t-esc="o.project_id.user_id.name"/>
                                    </t>
                                    <t t-else="">
                                        ____________________
                                    </t>
                                </div>
                            </td>

                            <!-- PLANNING -->
                            <td>
                                <strong>Planning Manager</strong>
                                <div style="margin-top:30px;">
                                    <t t-if="o.planning_approved_by and o.state in ['planning','operation','general']">
                                        <span t-esc="o.planning_approved_by.name"/>
                                    </t>
                                    <t t-else="">
                                        ____________________
                                    </t>
                                </div>
                            </td>

                            <!-- OPERATION -->
                            <td>
                                <strong>Operation Manager</strong>
                                <div style="margin-top:30px;">
                                    <t t-if="o.operation_approved_by and o.state in ['operation','general']">
                                        <span t-esc="o.operation_approved_by.name"/>
                                    </t>
                                    <t t-else="">
                                        ____________________
                                    </t>
                                </div>
                            </td>

                            <!-- GENERAL -->
                            <td>
                                <strong>General Manager</strong>
                                <div style="margin-top:30px;">
                                    <t t-if="o.general_approved_by and o.state == 'general'">
                                        <span t-esc="o.general_approved_by.name"/>
                                    </t>
                                    <t t-else="">
                                        ____________________
                                    </t>
                                </div>
                            </td>

                        </tr>

                    </table>

                </div>
            </xpath>

        </template>

    </data>
</odoo>