<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <record id="view_wizard_create_purchase_order_form" model="ir.ui.view">
        <field name="name">view.wizard.create.purchase.order.form</field>
        <field name="model">wizard.create.purchase.order</field>
        <field name="arch" type="xml">
            <form string="Create Purchase Order">
                <group>
                    <field name="partner_id"/>
                </group>
                <group>
                    <field name="type"/>
                </group>

                <footer>
                    <button string="Confirm" name="action_create_po" type="object" class="oe_highlight"/>
                    or
                    <button string="Cancel" class="oe_link" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_create_purchase_order" model="ir.actions.act_window">
        <field name="name">Create Purchase Order</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">wizard.create.purchase.order</field>
        <field name="view_id" ref="view_wizard_create_purchase_order_form"/>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
    <record id="purchase_order_form_inherit_max_qty" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.max.qty</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <!-- FORM VIEW -->
            <xpath expr="//field[@name='order_line']/form//field[@name='product_qty']" position="after">
                <field name="max_qty" readonly="1"/>
            </xpath>

        </field>
    </record>


    <record id="purchase_order_form_inherit_approval" model="ir.ui.view">
        <field name="name">purchase.order.form.approval</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">

                <!-- Planning Manager -->
                <button name="action_planning_approve"
                        string="Planning Manager Approve"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'draft'"/>

                <!-- Operation Manager -->
                <button name="action_operation_approve"
                        string="Operation Manager Approve"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'planning'"/>

                <!-- General Manager -->
                <button name="action_general_approve"
                        string="General Manager Approve"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'operation'"/>

            </xpath>

            <xpath expr="//button[@name='button_confirm']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

        </field>
    </record>

</odoo>
