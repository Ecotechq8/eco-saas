<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_order_form_inherit" model="ir.ui.view">
        <field name="name">sale.order.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="mode">primary</field>
        <field name="priority" eval="200"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="before">
                <button string="OM Approve" type="object" name="action_om_approve"
                        invisible="state != 'draft'" class="oe_highlight"
                        groups="eco_construction.group_so_operation_manager_approval"/>
                <button string="OM Reject" type="object" name="action_om_reject"
                        invisible="state != 'draft'" class="oe_highlight"
                        groups="eco_construction.group_so_operation_manager_approval"/>
                <button string="SM Approve" type="object" name="action_sm_approve"
                        invisible="state != 'om_approve'" class="oe_highlight"
                        groups="eco_construction.group_so_Sales_manager_approval"/>
                <button string="SM Reject" type="object" name="action_sm_reject"
                        invisible="state != 'om_approve'" class="oe_highlight"
                        groups="eco_construction.group_so_Sales_manager_approval"/>
                <button string="GM Approve" type="object" name="action_gm_approve"
                        invisible="not is_need_gm_approve or state not in 'sm_approve'" class="oe_highlight"
                        groups="eco_construction.group_so_general_manager_approval"/>
                <button string="GM Reject" type="object" name="action_gm_reject"
                        invisible="not is_need_gm_approve or state not in 'sm_approve'" class="oe_highlight"
                        groups="eco_construction.group_so_general_manager_approval"/>
                <button string="Create Payment" name="%(action_create_so_payment)d" type="action"
                        class="oe_highlight"/>
                <button string="Create Letter Of Guarantee" name="action_create_guarantee_letter" type="object"
                        class="oe_highlight"/>
                <button string="Create PO/Subcontracting" name="%(action_create_purchase_order)d" type="action"
                        class="oe_highlight"/>
            </xpath>
            <xpath expr="//button[@id='send_by_email_primary']" position="attributes">
                <attribute name="invisible">state != 'approved'</attribute>
            </xpath>
            <xpath expr="//button[@name='action_confirm'][2]" position="attributes">
                <attribute name="invisible">state != 'approved'</attribute>
            </xpath>
            <!--                        <xpath expr="//field[@name='state']" position="attributes">-->
            <!--                            <attribute name="statusbar_visible">"om_approve,om_reject,sm_approve,sm_reject,gm_approve,gm_reject,draft,sent,sale"</attribute>-->
            <!--                        </xpath>-->
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="move_boq" invisible="1"/>
                <field name="create_project" invisible="not opportunity_id"/>
                <field name="con_project_name" invisible="not opportunity_id" required="create_project"/>
                <field name="con_project_id" readonly="1" invisible="create_project == False"/>
                <field name="is_need_gm_approve"/>
                <field name="invoiced_amount" readonly="1" widget="monetary"/>
                <field name="progeres_invoice_no" readonly="state != 'draft'"/>

            </xpath>
            <xpath expr="//field[@name='country_code']" position="after">
                <field name="adv_percent" readonly="state == 'approved'"/>
                <field name="retention_percent" readonly="state == 'approved'"/>
            </xpath>
            <xpath expr="//page[@name='order_lines']" position="after">
                <page name="boq" string="Bill of Quantity" invisible="move_boq"
                      groups="eco_construction.group_sale_boq">
                    <field name="request_quota_line"
                           context="{'list_view_ref': 'eco_construction.request_quota_view_tree'}">
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="construction_sale_action" model="ir.actions.act_window">
        <field name="name">Construction</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,kanban,form,calendar,pivot,graph,activity</field>
        <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('sale.view_quotation_tree_with_onboarding')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('eco_construction.view_order_form_inherit')}),
                (0, 0, {'view_mode': 'kanban', 'view_id': ref('sale.view_quotation_kanban_with_onboarding')}),
                (0, 0, {'view_mode': 'pivot', 'view_id': ref('sale.view_sale_order_pivot')}),
                (0, 0, {'view_mode': 'graph', 'view_id': ref('sale.view_sale_order_graph')}),
            ]"/>
<!--        <field name="view_id" ref="eco_construction.view_order_form_inherit"/>-->
    </record>
    <menuitem
            id="root_construction_sale"
            name="Construction"
            web_icon="eco_construction,static/description/icon.png" sequence="25"
            groups="eco_construction.access_construction_group_sale"
    />


    <menuitem id="menuitem_construction_sale" name="Construction" sequence="1"
              parent="root_construction_sale"
              action="construction_sale_action"/>

</odoo>
