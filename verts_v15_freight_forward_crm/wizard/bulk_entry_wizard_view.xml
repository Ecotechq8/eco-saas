<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_box_details_wizard_form" model="ir.ui.view">
        <field name="name">box.details.wizard.form</field>
        <field name="model">box.details.wizard</field>
        <field name="arch" type="xml">
            <form string="Box Details Entry">
                <group>
                    <group>
                        <field name="total_boxes"/>
                        <field name="lead_id" invisible="1" force_save="1"/>
                    </group>
                    <group>
                        <field name="file" filename="filename"/>
                        <field name="filename" invisible="1"/>
                    </group>

                </group>

                <notebook>
                    <page string="Box Lines">
                        <field name="box_line_ids">
                            <list editable="bottom">
                                <field name="box_count"/>
                                <field name="commodity_type"/>
                                <field name="hs_code"/>
                                <field name="length"/>
                                <field name="width"/>
                                <field name="height"/>
                                <field name="weight"/>
                            </list>
                        </field>
                    </page>
                </notebook>

                <footer>
                    <button name="action_submit" string="Submit" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_box_details_wizard" model="ir.actions.act_window">
        <field name="name">Box Details Wizard</field>
        <field name="res_model">box.details.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_box_details_wizard_form"/>
    </record>
</odoo>
