<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_air_line_tree" model="ir.ui.view">
        <field name="name">air.line.tree</field>
        <field name="model">air.line</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
            </list>
        </field>
    </record>
    <record id="view_air_line_form" model="ir.ui.view">
        <field name="name">air.line.form</field>
        <field name="model">air.line</field>
        <field name="arch" type="xml">
            <form string="Inbound Flight">
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="name"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_configuration_menu" model="ir.actions.act_window">
        <field name="name">Air Line</field>
        <field name="res_model">air.line</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define your Airline here.
            </p>
        </field>
    </record>

</odoo>

