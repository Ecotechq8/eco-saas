<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Menu Actions -->
        <record id="action_air_line" model="ir.actions.act_window">
            <field name="name">Airlines</field>
            <field name="res_model">air.line</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_inbound_flight" model="ir.actions.act_window">
            <field name="name">Inbound Flights</field>
            <field name="res_model">inbound.flight</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_gsa_invoice" model="ir.actions.act_window">
            <field name="name">GSA Invoices</field>
            <field name="res_model">gsa.invoice</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Menus -->
        <menuitem id="menu_airport_operation_root" name="Airport Operations" sequence="50"/>

        <menuitem id="menu_airport_operation_flight" name="Flights" parent="menu_airport_operation_root" sequence="10"/>
        <menuitem id="menu_inbound_flight" name="Inbound Flights" parent="menu_airport_operation_flight" action="action_inbound_flight" sequence="10"/>

        <menuitem id="menu_airport_operation_gsa" name="GSA Invoices" parent="menu_airport_operation_root" action="action_gsa_invoice" sequence="20"/>

        <menuitem id="menu_airport_operation_config" name="Configuration" parent="menu_airport_operation_root" sequence="100"/>
        <menuitem id="menu_air_line" name="Airlines" parent="menu_airport_operation_config" action="action_air_line" sequence="10"/>
    </data>
</odoo>
